@model TrackTap.Models.StockUpdateModel
@{
    ViewBag.Title = "MonthlyAttendanceReport";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
}
<div class="row">
    @Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
    <div class="col-md-12">
        <div class="row">
            <div class="form-group col-sm-3">
                <div class="form-group">
                    <label>Category : </label>
                    <br />
                    @Html.DropDownListFor(m => m.CategoryId, TrackTap.DataLibrary.Data.DropdownData.GetLabCategories(Model.SchoolId), "   All   ", new { @class = "form-control slct-lab-category-dropdwn1", @data_live_search = "true", @style = "display:inline-block; width:100%;min-width:180px;" })
                    @Html.ValidationMessageFor(z => z.CategoryId)
                </div>
            </div>
            <div class="form-group col-sm-3">
                <div class="form-group">
                    <label> Print : </label>
                    <br />
                    <button class="btn pay-now-btn" id="btn-Print-bill" onclick="printContent('print-trial-bal')"><i class="fa fa-print"></i> Print</button>
                    <button class="btn pay-now-btn" id="btn-excel-trial-bal"><i class="fa fa-table"></i> Excel</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="table-responsive">
                <div class="col-md-12" id="print-trial-bal">
                    <h3 style="text-align:center;">INVENTORY REPORT</h3>
                    <h5 style="text-align:center;" id="inventory-report-head"></h5>
                    <table class="table " id="inventory-report-list" style="border-collapse: inherit;"></table>
                </div>
            </div>
        </div>

    </div>
</div>
<script>

    $(document).on('change', '.slct-lab-category-dropdwn1', function () {
        var catId = $(".slct-lab-category-dropdwn1 option:selected").val();
        var category = $(".slct-lab-category-dropdwn1 option:selected").text();
        if (catId != 0) {
            $.ajax({
                url: '/Laboratory/DatatableLabInventoryReport/' + catId,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    $('#inventory-report-head').text(category);
                    $('#inventory-report-list').html(data);
                }
            });
        }
        else {
            $.ajax({
                url: '/Laboratory/DatatableLabInventoryReport/' + 0,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    $('#inventory-report-head').text('All Category');
                    $('#inventory-report-list').html(data);
                }
            });
        }
    });

    $(document).ready(function () {
        $.ajax({
            url: '/Laboratory/DatatableLabInventoryReport/' + 0,
            type: "GET",
            dataType: 'html',
            success: function (data) {
                $('#inventory-report-head').text('All Category');
                $('#inventory-report-list').html(data);
            }
        });
    });

    function printContent(el) {
        var restorepage = document.body.innerHTML;
        var printcontent = document.getElementById(el).innerHTML;
        document.body.innerHTML = printcontent;
        window.print();
        document.body.innerHTML = restorepage;
        window.location.href = '/Laboratory/LabInventoryReport';
    };

    $(document).on('click', '#btn-excel-trial-bal', function () {

        var head= $(".slct-lab-category-dropdwn1 option:selected").text();
        $("#inventory-report-list").table2excel({
            name: "Table2Excel",
            filename: "LAB INVENTORY REPORT as on " + head,
            fileext: ".xls"
        });
    });
</script>