                <div class="with-icon" style="width: 150px; float: right; margin-right:10px;">
                    <input type="text" class="form-control bill-start-date" data-date-end-date="0d" value="@Model.SchoolModel.curredntDateTime.ToString("dd-MM-yyyy")">
                    <i class="fa fa-calendar"></i>
                </div>
                <select id="PaymentType" class="form-control" style="width: 150px; float: right; margin-right:380px;">
                    <option value="1" selected>Cash</option>
                    <option value="2">Cheque</option>
                    <option value="3">Bank Transfer</option>
                </select>
                @*<-----------ARCHANA ---------------PROMOTION------------->*@
                @*<h4 style="margin-top:10px;"><span>Academic Year</span> </h4>
                    @Html.DropDownListFor(m => m.AcademicYearId, TrackTap.Data.DropdownData.GetOtherAcademicYear(), new { @class = "form-control", @data_live_search = "true", id = "academic-year-dropdown-id-change", style = "width:25%;margin-bottom: 4px;margin-top: 4px;" })
                    @Html.ValidationMessageFor(z => z.AcademicYearId)*@
                @*<button class="btn pay-now-btn" data-toggle="model" id="btn-generate-prepaidInvoice">Prepaid Invoice</button>*@
                @*</-----------ARCHANA----------ADD DISCOUNT------------------->*@
                @*<button id="addDiscount-btn" class="btn pay-now-btn pull-right">Add Discount</button>*@
                @*<a href="/School/AssignDiscountFromBilling?id=@forAddDiscount" class="btn pay-now-btn pull-right" data-toggle="model" id="btn-Add-Discount">Add Discount</a>*@
                @*</-----------ARCHANA----------------------------->*@
            </div>
        </div>

        <div class="row form-group" style="margin-right: 0px !important;margin-left: 0px !important;">
            <div class="form-group">
                <div id="div-bakname" class="isHidden" style="width: 150px; float: right; margin-right:10px;">
                    <label>Bank Name</label>
                    @Html.DropDownListFor(m => m.BankId, TrackTap.Data.DropdownData.GetBankLists(Model.SchoolId), new { @class = "form-control accHead-drop-down" })
                    @Html.ValidationMessageFor(m => m.BankId)
                </div>

                <div class="isHidden" id="div-ckdate" style="width: 150px; float: right; margin-right:10px;">
                    <label>Cheque Date</label>
                    <div class="with-icon">
                        <input type="text" class="form-control chq-date setHeight" data-date-end-date="0d" value="@Model.SchoolModel.curredntDateTime.ToString("dd-MM-yyyy")">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
                <div id="div-chkno" class="isHidden" style="width: 150px; float: right; margin-right:10px;">
                    <label>Cheque Number</label>
                    <input type="text" class="form-control setHeight" value="" id="chk-no">
                </div>

            </div>
        </div>
        <div class="billingbox">
            <div id="billingList">
                @Html.Partial("~/Views/Laboratory/_pv_StockBilling_PaymentDetails_Grid.cshtml")
            </div>
        </div>

    </div><!-- end of col md 8 -->
</div>
