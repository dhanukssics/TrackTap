
@model TrackTap.Models.FeeModel
@{
    ViewBag.Title = "BillingDetails";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
    var forAddDiscount = Model.DivisionId + "~" + Model.SchoolModel.studentId;
}
<style>
    .setHeight {
        height: 34px !important;

    }


    .sp {
  padding: 20px;
  background-color: #f44336;
  color: white;
}

    .closebtn {
  margin-left: 15px;
  color: white;
  font-weight: bold;
  float: right;
  font-size: 22px;
  line-height: 20px;
  cursor: pointer;
  transition: 0.3s;
}

        .closebtn:hover {
            color: black;
        }
</style>

<div class="row close-this-window">
    <div class="col-md-12">
        <div class="form-group">
            <a href="/Laboratory/Billing" class="btn btn-peek"><i class="fa fa-arrow-left"></i> Back</a>
        </div>
        <h3>Billing Details </h3>

        <div class="table-responsive">
            <table class="table custome-table">
                <tr>
                    <th>
                        Name
                    </th>
                    <th>
                        Class
                    </th>
                    <th>
                        Division
                    </th>
                    <th>
                        Roll No.
                    </th>
                    <th>
                        Adm No.
                    </th>
                    <th>
                        Incharge
                    </th>
                </tr>
                <tr>
                    <td>
                        @Model.SchoolModel.studentName
                    </td>
                    <td>
                        @Model.SchoolModel.className
                    </td>
                    <td>
                        @Model.SchoolModel.division
                    </td>
                    <td>
                        @Model.SchoolModel.classNumber
                    </td>
                    <td>
                        @Model.AdmissionNo
                    </td>
                    <td>
                        @Model.SchoolModel.classInCharge
                    </td>
                </tr>
            </table>
        </div>
        <input type="hidden" id="hfStudentId" value="@Model.SchoolModel.studentId" />
        <input type="hidden" id="hfDivisionId" value="@Model.DivisionId" />
        <input type="hidden" id="hfAdnissionNo" value="@Model.AdmissionNo" />

