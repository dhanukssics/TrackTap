            i = i + 1;
        });
        var studentId = $('#studentId').val();
        var exam = $(this).attr('data-classId');
        var xx = studentId + '~' + exam;
        window.location = "/Student/ProgressCardGeneration/@Model.Data";
        var url = "/Student/ProgressCardGeneration/" + xx;
        window.open(url, '_blank');
    });*@
</script>