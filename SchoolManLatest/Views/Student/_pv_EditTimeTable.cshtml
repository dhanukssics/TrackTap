@model TrackTap.Models.TimetableModel
@{

}
@using (Ajax.BeginForm("EditTimeTableData", "Student", null, new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "EditTimeTableSuccess",
    OnFailure = "EditTimeTableFailure",
}, new { id = "form-login" }))
{
    @Html.HiddenFor(z => z.TableId, new { Value = Model.TableId,id="timeTableId" })
    <div class="col-md-4 col-md-offset-4 " role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel3">Edit Time Table</h4>
            </div>
            <div class="modal-body">
                <div class="row" style="width:100%; display:block; padding-left:20px;">
                    <div class="form-group">
                        <label style="color:black;">Teacher : </label>
                        <br />
                        @Html.DropDownListFor(m => m.TeacherId, TrackTap.DataLibrary.Data.DropdownData.GetTeachers(Model.SchoolId), new { @class = "form-control", @data_live_search = "true", @style = "display:inline-block; width:100%;min-width:180px;" })
                        @Html.ValidationMessageFor(z => z.TeacherId)
                    </div>
                    <div class="form-group">
                        <label style="color:black;">Subject : </label>
                        <br />
                        @Html.DropDownListFor(m => m.SubjectId, TrackTap.DataLibrary.Data.DropdownData.GetSubjectss(Model.SchoolId), new { @class = "form-control", @data_live_search = "true", @style = "display:inline-block; width:100%;min-width:180px;" })
                        @Html.ValidationMessageFor(z => z.SubjectId)
                    </div>
                    <div class="form-group">
                        <div class="col-lg-6">
                            <button type="button" class="btn pay-now-btn btn-peek" id="btn-timetable-delete">Delete</button>
                        </div>
                        <div class="col-lg-6">
                            <button type="submit" class="btn pay-now-btn" id="btn-timetable-edit">Save</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}