@model TrackTap.Models.OutstandingReportModel
@{

}
<div class="table-responsive">
    <table class="table account-table" id="tbstdMarkList" style="border-left: 0.5px solid #d2cece;border-right: 0.5px solid #d2cece;">
        <tr id="thead">
            <th>
                Sl.No
            </th>
            <th>
                Student Name
            </th>
            <th>
                Class
            </th>
            <th>
                Contact
            </th>
            <th>
                Amount
            </th>
        </tr>
        <tbody id="bodyTable">
            @{int count = 1;
            }

            @foreach (var item in Model.ReportList)
            {
                <tr class="cls-tr-class">
                    <td>
                        @count
                    </td>
                    <td>
                        @item.StudentName
                    </td>
                    <td>
                        @item.ClassName / @item.DivisionName
                    </td>
                    <td>
                        @item.ContactNumber
                    </td>
                    <td>
                        @String.Format("{0:0.00}",item.Amount)
                    </td>
                    
                </tr>
                count = count + 1;
            }

        </tbody>
    </table>
</div>