@model TrackTap.Models.BusReportModel

<div class="table-responsive">

    <table class="table custome-table table table-bordered">
        <thead>
            <tr>
                <th></th>
                <th>Details</th>                
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Bus Name</td>
                <td>@Model.BusName</td>
            </tr> 
            <tr>
                <td>Driver Name</td>
                <td>@Model.DriverModel.DriverName</td>                
            </tr> 
            <tr>
                <td>TripDate</td>
                <td>@Model.TripModel.TripDate</td>
            </tr> 
            <tr>
                <td>Start Time</td>
                <td>@Model.TripModel.StartTime</td>
            </tr> 
            <tr>
                <td>Reach Time</td>
                <td>@Model.TripModel.ReachTime</td>
            </tr> 
            <tr>
                <td>Location</td>
                <td>@Model.BusModel.LocationStart  To @Model.BusModel.LocationEnd </td>
            </tr> 
        </tbody>
    </table>


    <table class="table custome-table table-BusReport-list">
        <thead>
            <tr>
                <th>Sl.No</th>
                <th>Name</th>                
                <th>Contact Number</th>
                <th>Class</th>
                <th>Div</th>               
            </tr>
        </thead>


        <tbody>
            @{
                int i = 1;
                foreach (var one in Model.StudentsModel_Lists)
                {

                    
                        <tr style="cursor: pointer !important;">
                            <td class="student-row" data-id="">@i</td>
                            <td class="student-row" data-id="">@one.StundentName</td>
                            <td class="student-row" data-id="">@one.ContactNumber</td>
                            <td class="student-row" data-id="">@one.Class</td>
                            <td class="student-row" data-id="">@one.Division</td> 

                        </tr>
                    
                    

                    i = i + 1;
                }
            }
        </tbody>

    </table>
</div>
@*</div>
    </div>*@

