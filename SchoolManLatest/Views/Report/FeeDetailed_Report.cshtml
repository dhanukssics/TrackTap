@model TrackTap.Models.OutstandingReportModel
@{
    ViewBag.Title = "StudentMarks";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
}
@Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
@Html.HiddenFor(z => z.ClassId, new { Value = 0 })
@Html.HiddenFor(z => z.DivisionId, new { Value = 0 })

@*<link href="https://cdn.datatables.net/1.10.19/css/jquery.dataTables.min.css" rel="stylesheet">
<link href="https://cdn.datatables.net/buttons/1.5.6/css/buttons.dataTables.min.css" rel="stylesheet">

<script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.10.19/js/jquery.dataTables.min.js"></script>
<script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/buttons/1.5.6/js/dataTables.buttons.min.js"></script>
<script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/buttons/1.5.6/js/buttons.print.min.js"></script>

<script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/buttons/1.5.6/js/buttons.flash.min.js"></script>*@
<script type="text/javascript" charset="utf8" src="//code.jquery.com/jquery-1.10.2.min.js"></script>
<style>

    #print-trial-bal {
        height: 100%;
        width: 100%;
        
    }
    @@media print {
        
              #print-trial-bal{
                
                 height:auto;
                 width:auto;
                 overflow-y:hidden;
                }
        }
               
</style>

<div class="row">
    <div class="col-md-12">
        <div class="row">
            <div class="form-group col-sm-3">
                <div class="form-group">
                    <label>Academic Year : </label>
                    <br />
                    @Html.DropDownListFor(m => m.AcademicYearId, TrackTap.Data.DropdownData.GetOtherAcademicYear(), "All", new { @class = "form-control slct-academic-year-dropdwn1", @data_live_search = "true", @style = "display:inline-block; width:100%;min-width:180px;" })
                    @Html.ValidationMessageFor(z => z.AcademicYearId)
                </div>
            </div>
            <div class="form-group col-sm-3">
                <div class="form-group">
                    <label>Class :</label>
                    <select class="form-control slct-mark-dropdwn1" disabled id="classListId"></select>
                    <span id="class-required-exam-add" style="display:none; color:red;"></span>
                </div>
            </div>
            @*<div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Division :</label>
                        <select class="form-control slct-free-div-dropdown" disabled></select>
                        <span id="division-required-exam-add" style="display:none; color:red;"></span>
                    </div>
                </div>*@
            <div class="form-group col-sm-3">
                <div class="form-group">
                    <label>Fees : </label>
                    <br />
                    @Html.DropDownListFor(m => m.FeeId, TrackTap.Data.DropdownData.GetFeeses(Model.SchoolId), "All", new { @class = "form-control slct-fee-dropdwn1", @data_live_search = "true", @style = "display:inline-block; width:100%;min-width:180px;" })
                    @Html.ValidationMessageFor(z => z.FeeId)
                </div>
            </div>
            <div class="form-group col-sm-3">
                <label>Payment Status </label>
                <select class="form-control slct-payment-dropdown">
                    @* <option value="0" selected>---select---</option>*@
                    <option value="0" selected>Paid</option>
                    <option value="1">Pending</option>
                </select>
                @*  <span id="division-required-exam-add" style="display:none; color:red;"></span>*@
            </div>

        </div>

        <div class="row">

            @*<div class="form-group" id="chkDiv">
                    @Html.CheckBoxFor(m => m.IsSummary, new { @class = "", id = "report-IsSummary-Id" })
                    <span>Report Summary</span>
                </div>*@

            @*<div class="form-group col-sm-3 isHidden report-view">
                    <div class="with-icon">
                        <input type="text" style="height:40px;" class="form-control user-collection-start-date" data-date-end-date="0d">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>
                <div class="form-group col-sm-3 isHidden report-view">
                    <div class="with-icon">
                        <input type="text" style="height:40px;" class="form-control user-collection-end-date" data-date-end-date="0d">
                        <i class="fa fa-calendar"></i>
                    </div>
                </div>*@


            <div class="form-group col-sm-3">
                <button class="btn pay-now-btn" id="btn-Print-bill" onclick="printContent('print-trial-bal')"><i class="fa fa-print"></i> Print</button>
                <button class="btn pay-now-btn" id="btn-excel-trial-bal"><i class="fa fa-table"></i> Excel</button>
            </div>
        </div>
        <h3 style="text-align:center;">Fee Detailed Report</h3><h5 style="text-align:center;"></h5>

        <div class="table-responsive" id="print-trial-bal">
            @* <div id="outstanding-report-list" class="table-responsive"></div>*@
            @*<table class="display">

                </table>*@
        </div>

    </div>
</div>
<script>

    $(function () {
        $("#example").dataTable();
    })

    function IntializeDataTable() {
        $("#example").dataTable().fnDestroy();
        $("#example").dataTable
            ({
                paging: false,
                //scrollY: '400px',
               
                searching: false
                //scrollCollapse: true,
                
         });
           
    }

    $(document).on('change', '.slct-mark-dropdwn1', function () {
        debugger;
        var classId = $('.slct-mark-dropdwn1 option:selected').val();
        var feeId = $(".slct-fee-dropdwn1 option:selected").val();
        var Academicyear = $(".slct-academic-year-dropdwn1").val();
        var paidstatus = $(".slct-payment-dropdown").val();
        if (feeId == "")
            feeId = 0;
        if (classId != '') {
            var dataId = classId + '~' + feeId + '~' + Academicyear + '~' + paidstatus;

            $.ajax({
                url: '/Report/DatatablefeeReport/' + dataId,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    $("#print-trial-bal").html("");
                    $("#print-trial-bal").html(data);
                    IntializeDataTable();

                }
            });
        }

    });

    $(document).on('change', '.slct-fee-dropdwn1', function () {
        debugger;
        var classId = $('.slct-mark-dropdwn1 option:selected').val();
        var feeId = $(".slct-fee-dropdwn1 option:selected").val();
        var Academicyear = $(".slct-academic-year-dropdwn1").val();
        var paidstatus = $(".slct-payment-dropdown").val();
        if (feeId == "")
            feeId = 0;
        if (classId != '') {
            var dataId = classId + '~' + feeId + '~' + Academicyear + '~' + paidstatus;

            $.ajax({
                url: '/Report/DatatablefeeReport/' + dataId,
                type: "GET",
                dataType: 'html',
                success: function (data) {

                    //ViewDatePickers(); this to start.... 21-Nov-2020

                    $('#print-trial-bal').html("");

                    $('#print-trial-bal').html(data);
                    //$('#outstanding-report-list').DataTable();
                    IntializeDataTable();

                }
            });
        }

    });

    $(document).on('change', '.slct-payment-dropdown', function () {
        debugger;
        var classId = $('.slct-mark-dropdwn1 option:selected').val();
        var feeId = $(".slct-fee-dropdwn1 option:selected").val();
        var Academicyear = $(".slct-academic-year-dropdwn1").val();
        var paidstatus = $(".slct-payment-dropdown").val();
        if (feeId == "")
            feeId = 0;
        if (classId != '') {
            var dataId = classId + '~' + feeId + '~' + Academicyear + '~' + paidstatus;

            $.ajax({
                url: '/Report/DatatablefeeReport/' + dataId,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    console.log(data);
                    $('#print-trial-bal').html("");
                    $('#print-trial-bal').html(data);
                    IntializeDataTable();
                }
            });
        }

    });

    function printContent(el) {
        var restorepage = document.body.innerHTML;
        var printcontent = document.getElementById(el).innerHTML;
        document.body.innerHTML = printcontent;
        window.print();
        document.body.innerHTML = restorepage;
        //window.location.href = '/Report/OutstandingReport';
    }

    $(document).on('click', '#btn-excel-trial-bal', function () {
        $("#print-trial-bal").table2excel({
            name: "Table2Excel",
            filename: "FeeDetailed Report",
            fileext: ".xls"
        });
    });


    $(document).on('change', '.slct-academic-year-dropdwn1', function () {
        //debugger;
        $('#outstanding-report-list').html('');
        $('#AcademicYearId').val($(this).val());
        var id = $(this).val();
        if (id != '') {
            $.ajax({
                url: '/Data/LoadAllSchoolClassWithAcademicYear?academicYear=' + id + '&schoolid=' + $('#SchoolId').val(),
                type: "GET",
                success: function (result) {
                    if (result.list.length > 0) {
                        $(".slct-mark-dropdwn1").html("");
                        $(".slct-mark-dropdwn1").append($('<option></option>').val("0").html('-- Select Class --'));
                        $.each(result.list, function (i, item) {
                            $(".slct-mark-dropdwn1").append($('<option></option>').val(item.Value).html(item.Text));
                        });
                        $(".slct-mark-dropdwn1").prop("disabled", false);
                        //ViewDatePickers();
                    }
                    else {
                        $(".slct-mark-dropdwn1").html("");
                        $(".slct-mark-dropdwn1").append($('<option></option>').val("0").html('-- No Class Found --'));
                        $(".slct-mark-dropdwn1").prop("disabled", true);
                        $('#DivisionId').val("0");
                        HideDatePickers();
                    }
                }
            });
        }
        else {
            $(".slct-mark-dropdwn1").html("");
            $(".slct-mark-dropdwn1").append($('<option></option>').val("0").html('-- Select Class --'));
            $(".slct-mark-dropdwn1").prop("disabled", true);
            //start();
            HideDatePickers();
        }
    });

    $('#report-IsSummary-Id').change(function () {
        //debugger;
        var $dd = $('#slct-mark-dropdwn1');
        var length = document.getElementById("classListId").options.length;
        var classId = $(".slct-mark-dropdwn1 option:selected").val();
        var divId = $(".slct-free-div-dropdown option:selected").val();
        var feeId = $(".slct-fee-dropdwn1 option:selected").val();
        if (feeId == "")
            feeId = 0;
        //if ($dd.find('option').length >= 1) {
        if (length >= 2) {
            var dataId = classId + '~' + divId + '~' + feeId;
            if ($('#report-IsSummary-Id').is(":checked")) {
                dataId = dataId + '~' + 1;
            }
            else {
                dataId = dataId + '~' + 0;
            }
            if ($('.user-collection-start-date').val() != '') {
                var xx = $('.user-collection-start-date').val().replace("/", "-");
                xx = xx.replace("/", "-")
                dataId = dataId + '~' + xx;
            }
            if ($('.user-collection-end-date').val() != '') {
                var xx = $('.user-collection-end-date').val().replace("/", "-");
                xx = xx.replace("/", "-")
                dataId = dataId + '~' + xx;
            }
            $.ajax({
                url: '/Report/DatatableOutStandingReport/' + dataId,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    $('#outstanding-report-list').html(data);

                }
            });
        }
        else {
            start();
        }
    });

  



</script>
