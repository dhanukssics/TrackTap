
@model TrackTap.Models.UpPublishedClassList
@{
}
<thead>
    <tr>
        <th>
            Slno
        </th>
        <th>
            Class
        </th>
        <th>
            Division
        </th>
        <th>
            Academic Year
        </th>
        <th>

        </th>
    </tr>
</thead>
<tbody>
    @foreach (var item in Model.list)
    {
        <tr>
            <td>
                @item.SlNo
            </td>
            <td>
                @item.ClassName
            </td>

            <td>
                @item.DivisionName
            </td>
            <td>
                @item.AccademicYear
            </td>
            <td>
                <button class="publish-class-tr btn btn-sm btn-info" data-classid="@item.ClassId" data-divid="@item.DivisionId">Publish</button>
            </td>
        </tr>
    }





</tbody>