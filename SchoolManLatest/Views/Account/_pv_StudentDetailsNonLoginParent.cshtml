@model TrackTap.Models.StudentModel
@{
    var student = new TrackTap.Data.School(Model.schoolId).GetStudentForParent(Model.admissionNo).FirstOrDefault();
}
<style>
    .login-without .login-form p span {
        font-weight: normal;
        margin-left: 10px;
    }
      .login-without .login-form p {
           font-weight: bold;

    }
</style>

@if (student != null)
{
    <div class="form-group">
        <div style="height:150px;padding-top:10px;" class="newDes">
            <div> <p>Name: <span>@student.StundentName</span></p></div>
            <div><p>Class: <span>@student.ClassName</span></p> </div>
            <div> <p>Div: <span>@student.DivisionName</span></p></div>
        </div>
    </div>
    <div class="form-group">
        <input id="proceed-detail" type="button" value="PROCEED" class="submit" data-studentId="@student.StudentId" data-admission="@Model.admissionNo" />
    </div>
}
else
{
    <span id="val-admission">Wrong admission number</span>
}

<script>
    $(document).on('click', '#proceed-detail', function () {
        var studentId = $(this).attr("data-studentId");
        var admission = $(this).attr("data-admission");
        window.location.href = '/Account/BillingDetails/' + studentId + '~' + admission;
    });

</script>