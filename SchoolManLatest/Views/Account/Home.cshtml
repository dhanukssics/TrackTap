<section class="whitebg">
    <div class="container">
        <h1 class="header-main-h1 white_head">why <span class="question">Schoolman ?</span></h1>
        <div class="white_cnts">
            <div class="row">
                <div class="col-lg-6 col-md-12 col-sm-12 col-xs-12">
