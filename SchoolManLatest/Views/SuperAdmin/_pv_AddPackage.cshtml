@model TrackTap.Models.SmsPackageModels

<div class="modal-dialog modal-sm" role="document">

    <style>
        span {
            color: red;
        }
    </style>

    @using (Ajax.BeginForm("AddSmsPackage", "SuperAdmin", null, new AjaxOptions
    {
        HttpMethod = "POST",
        OnSuccess = "AddSmsPackageSuccess",
        OnFailure = "ajaxFailure",
    }, new { id = "form-login" }))
    {
        @Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">Add Package</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>From Date</label>
                    <div class="calendar-inp pos_icon_adj">
                        <i class="fa fa-calendar" style="margin-left: 90%;"></i>
                        @Html.TextBoxFor(m => m.FromDate, new { @class = "form-control", placeholder = "" })
                        @*@Html.ValidationMessageFor(m => m.DOBstring)*@
                    </div>
                </div>
                <div class="form-group">
                    <label>To Date</label>
                    <div class="calendar-inp pos_icon_adj">
                        <i class="fa fa-calendar" style="margin-left: 90%;"></i>
                        @Html.TextBoxFor(m => m.ToDate, new { @class = "form-control", placeholder = "" })
                        @*@Html.ValidationMessageFor(m => m.DOBstring)*@
                    </div>
                </div>
                <div class="form-group">
                    <label>AllowedSms</label>
                    @Html.TextBoxFor(m => m.AllowedSms, new { autocomplete = "off", placeholder = "Allowed Sms", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.AllowedSms)
                    @*<input class="form-control" placeholder="Division" type="text" />*@
                </div>
                <div class="form-group">
                    <label>Rate</label>
                    @Html.TextBoxFor(m => m.SmsRate, new { autocomplete = "off", placeholder = "Rate", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.SmsRate)
                    @*<input class="form-control" placeholder="Division" type="text" />*@
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button class="btn pay-now-btn">Save</button>
            </div>
        </div>
    }
</div>
