@model TrackTap.Models.AttendanceModels
@{
    var studentList = new TrackTap.DataLibrary.Data.Division(Model.divisionId).GetStudentDetails();
    var studentCount = studentList.Count();
}
<style>
    img {
        width: 100px;
    }

    .select-box {
        border-radius: 5px;
        border: 2px solid green;
        width: 120px;
        /*height: 120px;*/
        text-align: center;
        z-index: 99;
        float: left;
        /*padding: 5px;*/
        margin-right: 10px;
        margin-bottom: 10px;
        min-height: 192px;
        cursor: pointer;
    }

        .select-box.active {
            border: 2px solid red;
        }
        .select-box.active span {
            color:red;
        }

        .select-box input[type=checkbox] {
            display: none;
        }

        .select-box span {padding: 5px; display: inline-block; font-weight: bold;}
</style>
<input type="hidden" id="hfStdCount" value="@studentCount" />
<div class="select-box-all">
    @foreach (var student in studentList)
    {

        <div class="select-box">
            @if (student.FilePath != null)
            {
                <img style="max-height:118px" src="@student.FilePath" />
            }
            else
            {
            <img src="~/Content/img/children-1.gif" />
            }
            <input class="checkboxAttendance" data-studentId="@student.StudentId" data-status="True" type="checkbox" name="openings" value="@student.StudentId"> <span>@student.StundentName</span>
        </div>
    }

</div>

<script>
    $(document).ready(function () {
        sumTotal();
        $('#btn-save-attendance').removeClass('isHidden');
        $('#btn-save-attendance').html('Save');

    })
    $('.select-box').click(function (e) {
        if ($(this).children('input').prop("checked")) {
            $(this).children('input').prop("checked", false);
            $(this).removeClass('active');
            $(this).children('input').attr("data-status", "True");
            //console.log($(this).children('input').attr("data-status"));
        }
        else {
            $(this).children('input').prop("checked", true);
            $(this).addClass('active');
            $(this).children('input').attr("data-status", "False");
            //console.log($(this).children('input').attr("data-status"));
        }
        sumTotal();
    });

  
</script>