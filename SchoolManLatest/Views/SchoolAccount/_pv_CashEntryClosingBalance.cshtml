
@model TrackTap.Models.DayBookReportModel
@{
    long bankId = 0;
    int sourceId = 0;//From Status Cash ...0:Cash,1:Bill,2:Bank
    var data = new TrackTap.DataLibrary.Data.School(Model.SchoolId).GetClosingBalance(Model.ToDate, bankId, sourceId);
}
<div class="row">
    @if (data != null)
    {
        <span>
            <label style="margin-right:50px;">Closing Balance: @data /- </label>
        </span>
    }
    else
    {

    }
</div>
