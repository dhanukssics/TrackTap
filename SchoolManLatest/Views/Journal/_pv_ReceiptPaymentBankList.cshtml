
@model TrackTap.Models.ReceiptPaymentModel
@{
    var receiptPayment = new TrackTap.DataLibrary.Data.School(Model.SchoolId).GetReceiptPaymentBankData();
    var openingBankBalance = new TrackTap.DataLibrary.Data.School(Model.SchoolId).GetReceiptPaymentBankDataByDate(Model.StartDate);
    var cashInHand = new TrackTap.DataLibrary.Data.School(Model.SchoolId).GetCashBookStatus(Model.StartDate, Model.EndDate);

}
<div class="row">
    <div class="col-md-6" id="print-trial-bal">
        <table class="table custome-table table-bordered" id="table-trial-balance">
            <thead>
                <tr>
                    <th colspan="2" style="text-align: center; border:1px solid #ddd !important">
                        Opening Balance
                    </th>
                </tr>
               
            </thead>
            <tbody>
                <tr>
                    <td style="text-align: left;">
                        <b>Head</b>
                    </td>
                    <td style="text-align: center;">
                        <b>Amount</b>
                    </td>
                </tr>
            <td style="text-align: left;">
                Cash in hand
            </td>
            <td style="text-align: center;">
                @cashInHand[0].OpeningBalance
            </td>
            </tr>
                @{
                    foreach (var item in receiptPayment)
                    {
                        <tr>
                            <td>
                                @item.BankName
                            </td>
                            <td style="text-align: center;">
                                @String.Format("{0:0.00}", item.amount)
                            </td>
                        </tr>
                    }
                }
            </tbody>



        </table>
    </div>



    <div class="col-md-6" id="print-trial-bal">
        <table class="table custome-table table-bordered" id="table-trial-balance">
            <thead>
                <tr>
                    <th colspan="2" style="text-align: center; border:1px solid #ddd !important">
                        Closing Balance
                    </th>
                </tr>

            </thead>
            <tbody>
              
                <tr>
                    <td style="text-align: left;">
                        <b>Head</b>
                    </td>
                    <td style="text-align: center;">
                        <b>Amount</b>
                    </td>
                </tr>
                <tr>
                    <td style="text-align: left;">
                        Cash in hand
                    </td>
                    <td style="text-align: center;">
                        @cashInHand[0].ClosingBalance
                    </td>
                </tr>
                @{
                    foreach (var item in openingBankBalance)
                    {
                        <tr>
                            <td>
                                @item.BankName
                            </td>
                            <td style="text-align: center;">
                                @String.Format("{0:0.00}", item.amount)
                            </td>
                        </tr>
                    }
                }
            </tbody>



        </table>
    </div>


</div>