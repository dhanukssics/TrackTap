@model TrackTap.Models.BankBookModel
@{

}

@using (Ajax.BeginForm("EditBankBook", "Journal", null, new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "EditBankBookSuccess",
    OnFailure = "EditBankBookFailed",
}, new { id = "form-login" }))
{
    @Html.HiddenFor(m => m.BankBookId)
    <div class="col-md-6">
        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Bank Name</label>
            </div>
            <div class="col-md-9">
                @Html.DropDownListFor(m => m.BankId, TrackTap.Data.DropdownData.GetBankLists(Model.SchoolId), "--Choose--", new { @class = "form-control ", id = "day-bank-Name-id" })
                @Html.ValidationMessageFor(m => m.BankId)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Type</label>
            </div>
            <div class="col-md-9">
                @Html.EnumDropDownListFor(m => m.TypeId, "--Choose--", new { @class = "form-control pv_account-type", @data_live_search = "true", name = "classDropdown", id = "day-book-type-id" })
                @Html.ValidationMessageFor(m => m.TypeId)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Date</label>
            </div>
            <div class="col-md-9 calendar-inp pos_icon_adj">
                @Html.TextBoxFor(m => m.EntryDateString, new { @class = "form-control date-bankBook-add-date", placeholder = "" })
                <i class="fa "></i>
                @*@Html.ValidationMessageFor(m => m.EntryDateString)*@
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Voucher No</label>
            </div>
            <div class="col-md-9">
                @Html.TextBoxFor(m => m.VoucherNo, new { autocomplete = "off", placeholder = "Voucher No", @readonly = "readonly", @class = "form-control" })
              
            </div>
        </div>

        @*<div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Bank Name</label>
            </div>
            <div class="col-md-9">
                @Html.DropDownListFor(m => m.BankId, TrackTap.Data.DropdownData.GetBankLists(Model.SchoolId), "--Choose--", new { @class = "form-control ", id = "day-bank-Name-id" })
                @Html.ValidationMessageFor(m => m.BankId)
            </div>
        </div>*@

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Account Head</label>
            </div>
            <div class="col-md-9">
                @Html.DropDownListFor(m => m.HeadId, TrackTap.Data.DropdownData.GetAccountHeads(Model.SchoolId), "--Choose--", new { @class = "form-control accHead-drop-down", @data_live_search = "true", name = "classDropdown", id = "day-book-head-id" })
                @Html.ValidationMessageFor(m => m.HeadId)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>SubLedger</label>
            </div>
            <div class="col-md-9">
                @Html.DropDownListFor(m => m.SubLedgerId, new SelectList(
                  new List<Object>{
                       new { value = 0 , text = "--select division--"  }
                    },
                  "value",
                  "text"
                   ), new { @class = "form-control ", @data_live_search = "true", @disabled = "disabled" })
                @Html.ValidationMessageFor(m => m.SubLedgerId)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Amount</label>
            </div>
            <div class="col-md-9">
                @Html.TextBoxFor(m => m.Amount, new { autocomplete = "off", placeholder = "Amount", @class = "form-control", id = "bank-book-current-balance-check-edit" })
                <span id="spn-error-current-balance-check" data-val="0" data-myval="10" style="color:red;"></span>
                @Html.ValidationMessageFor(z => z.Amount)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Narration</label>
            </div>
            <div class="col-md-9">
                @Html.TextBoxFor(m => m.Narration, new { autocomplete = "off", placeholder = "Narration", @class = "form-control" })
                @Html.ValidationMessageFor(z => z.Narration)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Cheque No</label>
            </div>
            <div class="col-md-9">
                @Html.TextBoxFor(m => m.ChequeNo, new { autocomplete = "off", placeholder = "Narration", @class = "form-control" })
                @Html.ValidationMessageFor(z => z.Narration)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-3">
                <label>Cheque Date</label>
            </div>
            <div class="col-md-9 calendar-inp pos_icon_adj">
                @Html.TextBoxFor(m => m.ChequeDateString, new { @class = "form-control date-bankBook-add-date", placeholder = "" })
                <i class="fa "></i>
                @Html.ValidationMessageFor(m => m.ChequeDateString)
            </div>
        </div>


        <div class="form-group gap_bottom">
            <div class="modal-footer">
                <button type="button" id="btn-cancel-bankbook" class="btn ">Cancel</button>
                <button type="submit" id="btn-edit-save-bankbook" class="btn pay-now-btn">Edit</button>
                <button type="button" id="btn-print-bankbook-edit" class="btn pay-now-btn">Print</button>
            </div>
        </div>
    </div>
}

<script>
    $(document).ready(function () {
        //debugger;
        var headid = @Model.HeadId;
        var subledgid =@Model.SubLedgerId;
        $.ajax({
            url: '/Data/LoadSubLedgerList?id=' + headid,
            type: "GET",
            success: function (result) {
                if (result.list.length > 0) {
                    $("#SubLedgerId").html("");
                    $("#SubLedgerId").append($('<option></option>').val("").html('-- Select SubLedger --'));
                    $.each(result.list, function (i, item) {
                        $("#SubLedgerId").append($('<option></option>').val(item.Value).html(item.Text));
                        $("#SubLedgerId").val(subledgid);
                        var Id = $('#SubLedgerId').val();
                        $('#SubLedgerName').val(Id);
                    });
                    $("#SubLedgerId").prop("disabled", false);
                    $("#day-book-type-id").attr("disabled","disabled");
                }
                else {
                    $("#SubLedgerId").html("");
                    $("#SubLedgerId").append($('<option></option>').val("").html('-- No SubLedger Found --'));
                    $("#SubLedgerId").prop("disabled", true);
                    $("#day-book-type-id").attr("disabled","disabled");
                }
            }
        });

    });
</script>