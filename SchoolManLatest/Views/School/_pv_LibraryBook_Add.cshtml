
@model TrackTap.Models.LibraryModels

<div class="modal-dialog modal-sm" role="document">

    <style>
        span {
            color: red;
        }
    </style>

    @using (Ajax.BeginForm("AddLibraryBook", "School", null, new AjaxOptions
    {
        HttpMethod = "POST",
        OnSuccess = "AddBookSuccess",
        OnFailure = "ajaxFailure",
    }, new { id = "form-teacher-add" }))
    {
        @*@Html.HiddenFor(m => m.categoryId)*@

        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">Add Book</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>
                    @Html.TextBoxFor(m => m.title, new { autocomplete = "off", placeholder = "Name", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.title)
                </div>
                <div class="form-group">
                    <label>Author</label>
                    @Html.TextBoxFor(m => m.author, new { autocomplete = "off", placeholder = "Author", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.author)
                </div>
                @*<div class="form-group">
                    <label>Status</label>
                    @Html.TextBoxFor(m => m.status, new { autocomplete = "off", placeholder = "Status", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.status)
                </div>*@
                <div class="form-group">
                    <label>Category</label>
                    @Html.DropDownListFor(m => m.categoryId, new TrackTap.Data.DropdownData().GetBookCategory(Model.schoolId), "--Choose Category--", new { @class = "form-control slct-fee-dropdwn", @data_live_search = "true" })
                    @Html.ValidationMessageFor(z => z.categoryId)
                </div>
                <div class="form-group">
                    <input type="checkbox" name="" value="" id="chk-bulk-book"> Bulk Book<br>
                    @Html.TextBoxFor(m => m.bookCount, new { autocomplete = "off", placeholder = "", @class = "form-control isHidden" })
                    @Html.ValidationMessageFor(z => z.bookCount)
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="submit" id="btn-addteacher" class="btn pay-now-btn">Save</button>
            </div>
        </div>
    }
</div>
<script>

    $(document).on('change', '#chk-bulk-book', function () { 
        if (this.checked) {
            $("#bookCount").removeClass('isHidden');

        }
        else {
            $("#bookCount").addClass('isHidden');
            $("#bookCount").val(1);
        }
    });
</script>
