@model TrackTap.Models.TeacherEditModel
@{
    var teacher = new TrackTap.DataLibrary.Data.Teacher(Model.teacherId);
    var salary = new TrackTap.DataLibrary.Data.School(Model.schoolId).SalaryTypeStatus();
    if (teacher != null)
    {
        if (teacher.TeacherClass.Count > 0)
        {
            foreach (var item in teacher.TeacherClass)
            {
                Model.classId = item.ClassId.ToString();
                Model.divisionId = item.DivisionId.ToString();
            }
        }
        else
        {
            Model.classId = Convert.ToString(0);
            Model.divisionId = Convert.ToString(0);
        }
        Model.contactNumber = teacher.ContactNumber;
        Model.emailId = teacher.Email;
        Model.filePath = teacher.FilePath;
        Model.teacherName = teacher.TeacherName;
        if (salary == 0)
        {
            Model.SalaryType = "Basic Salary";
        }
        else
        {
            Model.SalaryType = "Gross Salary";
        }
        Model.SalaryAmount = teacher.SalaryAmount ?? 0;
        Model.PFPercentage = teacher.PFPercentage ?? 0;
        Model.ESIPercentage = teacher.ESIPercentage ?? 0;
        if (teacher.IsPermanent != null)
        {
            Model.IsPermanent = teacher.IsPermanent??false;
        }
        else
        {
            Model.IsPermanent = false;
        }
        if (teacher.UserType != null)
        {
            Model.UserTypeId = teacher.UserType;
        }
        Model.DOJstring = Convert.ToString(teacher.DOJ);
    }
}

<div class="modal-dialog modal-lg" role="document">

    <style>
        span {
            color: red;
        }

        .textBoxShade {
            border: 1px solid black !important;
        }
    </style>

    @using (Ajax.BeginForm("EditTeacher", "School", null, new AjaxOptions
    {
        HttpMethod = "POST",
        OnSuccess = "EditTeacherSuccess",
        OnFailure = "ajaxFailure",
    }, new { id = "form-teacher-edit" }))
    {
        @Html.HiddenFor(z => z.schoolId, new { Value = Model.schoolId })
        @Html.HiddenFor(z => z.divisionId, new { Value = Model.divisionId })
        @Html.HiddenFor(z => z.teacherId, new { Value = Model.teacherId })
        @Html.HiddenFor(z => z.classId, new { Value = Model.classId })
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">Edit Teacher</h4>
            </div>
            <div class="modal-body">
                <div class="row col-lg-12">
                    <div class="form-group col-lg-6">
                        <label>Name</label>
                        @Html.TextBoxFor(m => m.teacherName, new { autocomplete = "off", placeholder = "Name", @class = "form-control textBoxShade" })
                        @Html.ValidationMessageFor(z => z.teacherName)
                    </div>
                    <div class="form-group col-lg-6">
                        <label>Email</label>
                        @Html.TextBoxFor(m => m.emailId, new { autocomplete = "off", placeholder = "E-mail", @class = "form-control textBoxShade" })
                        @Html.ValidationMessageFor(z => z.emailId)
                    </div>

                </div>
                <div class="row col-lg-12">
                    <div class="form-group col-lg-4">
                        <label>Contact No.</label>
                        @Html.TextBoxFor(m => m.contactNumber, new { autocomplete = "off", placeholder = "Contact Number", @class = "form-control textBoxShade" })
                        @Html.ValidationMessageFor(z => z.contactNumber)
                    </div>
                    <div class="form-group col-lg-2" id="chkDiv">
                        <br />
                        <label>Permanent</label>
                        <br />
                        @Html.CheckBoxFor(m => m.IsPermanent, new { @class = "", id = "cash-check-id" })
                        @Html.ValidationMessageFor(z => z.IsPermanent)
                    </div>
                    <div class="form-group col-lg-3">
                        <label>Class</label>
                        <select class="form-control slct-teacherclass-dropdwn textBoxShade">
                            <option value="0">--Choose--</option>
                            @foreach (var item in new TrackTap.DataLibrary.Data.DropdownData().GetFreeTeacherClasses(Model.schoolId, Model.teacherId))
                            {
                                <option value="@item.Value" @(Model.classId == item.Value ? "selected" : "")>@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="form-group col-lg-3">
                        <label>Division</label>
                        <select class="form-control slct-free-div-dropdown textBoxShade">
                            <option value="0">--Choose--</option>
                            @foreach (var item in new TrackTap.DataLibrary.Data.DropdownData().GetFreeTeacherDivision(Model.classId, Model.teacherId))
                            {
                                <option value="@item.Value" @(Model.divisionId == item.Value ? "selected" : "")>@item.Text</option>
                            }
                        </select>
                        <span id="division-required-teacher-edit" style="display:none;"></span>
                    </div>
                </div>

                <div class="row col-lg-12">
                    <div class="form-group col-lg-4">
                        <label>@Model.SalaryType</label>
                        @Html.TextBoxFor(m => m.SalaryAmount, new { autocomplete = "off", type = "number", placeholder = "Name", @class = "form-control textBoxShade" })
                    </div>
                    <div class="col-lg-4">
                        <label>PF %</label>
                        @Html.TextBoxFor(m => m.PFPercentage, new { autocomplete = "off", type = "number", placeholder = "Name", @class = "form-control textBoxShade" })
                    </div>
                    <div class="col-lg-4">
                        <label>ESI %</label>
                        @Html.TextBoxFor(m => m.ESIPercentage, new { autocomplete = "off", type = "number", placeholder = "Name", @class = "form-control textBoxShade" })
                    </div>
                </div>
                <div class="row col-lg-12">
                    <div class="form-group col-lg-6">
                        <label>User Type</label>
                        @Html.DropDownListFor(m => m.UserTypeId, new TrackTap.DataLibrary.Data.DropdownData().GetAllTeacherUserTypeDataAdd(Model.schoolId), "--Choose--", new { @class = "form-control", @data_live_search = "true" })
                    </div>
                    <div class="form-group col-lg-6">
                        <label>DOJ</label>
                        <div class="calendar-inp pos_icon_adj ">
                            <i class="fa fa-calendar" style="margin-left: 90%;"></i>
                            @Html.TextBoxFor(m => m.DOJstring, new { @class = "form-control dob-get-data-cls ", placeholder = "" })
                            @Html.ValidationMessageFor(m => m.DOJstring)
                        </div>
                    </div>
                </div>       

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="submit" style="display:none;" id="btn-editteacher" class="btn pay-now-btn">Edit Teacher</button>
                <button type="button" id="btn-dummy-editteacher" class="btn pay-now-btn">Edit Teacher</button>
            </div>
        </div>
    }
</div>
<script>
    $('#DOJstring').datepicker({
        format: "dd-mm-yyyy",
        autoclose: true,
        todayHighlight: true,
        //startDate: '-3d'
        endDate: '+d'
    });


</script>