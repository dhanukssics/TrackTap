@model TrackTap.Models.FeeModel
@{
    var fees = new TrackTap.DataLibrary.Data.Student(Model.SchoolModel.studentId).GetStudentCommonFeeList();
}
@using (Ajax.BeginForm("CommonFeeDiscountStudentFee", "School", null, new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "EditFeeStudentSuccess",
    OnFailure = "ajaxFailure",
}, new { id = "form-login" }))
{
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">Discount in Common Fees</h4>
            </div>
            <div class="modal-body">
                @Html.HiddenFor(m => m.StudentId, new { Value = @Model.SchoolModel.studentId, id = "studentIdId" })
                @if (fees.Count > 0)
                {
                    <div>
                        <div class="table-responsive">
                            <table class="table custome-table table-striped" style="margin:0px;">
                                <tr>
                                    <th>
                                        Particulars
                                    </th>
                                    <th style="width:20%; text-align: right;">
                                        Amount
                                    </th>
                                </tr>
                                @foreach (var fee in fees)
                    {
                                    <tr class="feeclass-tr" data-feeid="@fee.FeeId" data-dueDate="@fee.DueDate" data-OldAmount="@fee.Amount">
                                        <td>
                                            <input type="text" class="form-control" readonly="readonly" value="@fee.Feename - @String.Format("{0:y}", fee.DueDate)" />
                                        </td>
                                        <td style="width:20%; text-align: right;">
                                            <input type="text" class="form-control loop-class-amount1" value="@String.Format("{0:0.00}", fee.Amount)" />
                                        </td>
                                    </tr>
                                }
                                @Html.HiddenFor(m => m.FeeDetails)

                            </table>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button class="btn pay-now-btn" id="btn-dummysubmit-editclass1"> save</button>
                        <button type="submit" id="btn-submit-editclass" class="isHidden"> </button>
                    </div>
                }
                else
                {
                    <div>
                        <span>No fees to edit.</span>
                    </div>
                }
            </div>
        </div>
    </div>
}
<script>
    $(document).on('click', '#btn-dummysubmit-editclass1', function () {
        var list = [];
        $('.feeclass-tr').each(function (i, obj) {
            var source = $(this);
            var amount = $(source).find('.loop-class-amount1').val();
            if (amount != "") {
                var feeStudentId = $(source).attr('data-feeid');
                var dueDate = $(source).attr('data-dueDate');
                var Obj = new Object();
                Obj.feeStudentId = feeStudentId;
                Obj.DueDate = dueDate;
                Obj.StudentId = $('#studentIdId').val();
                Obj.OldAmount = $(source).attr('data-OldAmount');
                Obj.amount = amount;
                list.push(Obj);
            }
        });
        $('#FeeDetails').val(JSON.stringify(list));
        console.log($('#FeeDetails').val());
        $('#btn-submit-editclass').trigger('click');
    });
</script>
