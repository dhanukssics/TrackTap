@model TrackTap.Models.FeeModel

<!-------------------------------------->
<style>
    .modal-dialog {
        width: 60% !important;
        height: 42% !important;
        margin: 0 auto;
        margin-top: 1.3%;
        padding: 0;
    }

    #form-inputbox tr td, #form-inputbox tr, .custome-table tr td {
        vertical-align: top !important;
    }
</style>
<div class="modal-dialog" role="document">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title" id="myModalLabel">Add Payment</h4>
        </div>
        @using (Ajax.BeginForm("AddAdditionalFeeStudent", "School", null, new AjaxOptions
        {
            HttpMethod = "POST",
            OnSuccess = "AddFeeStudentSuccess",
            OnFailure = "ajaxFailure",
        }, new { id = "form-login" }))
        {
            <div class="modal-body">
                <div class="table-responsive">

                    @Html.HiddenFor(m => m.FeeId)
                    @Html.HiddenFor(m => m.StudentId)
                    @* @Html.HiddenFor(m => m.SchoolId, new { Value = Model.SchoolId })*@
                    <table class="table custome-table table-striped" style="margin:0px; height: 478px; overflow: auto; display: block;">
                        <tr>
                            <th>
                                Particulars
                            </th>
                            <th style="width:20%; text-align: right;">
                                Amount
                            </th>
                        </tr>
                        <tr id="form-inputbox">
                            <td>
                               <input type="text" class="form-control my_form" autocomplete="off" id="autoFeeId" placeholder="Fee name" maxlength=50 />
                            </td>
                            <td style="width:20%; text-align: right;">
                                <input  class="form-control my_form"  id="Amount" type = "number" autocomplete="off"  placeholder="Amount" />
                            </td>
                        </tr>
                        @foreach (var data in new TrackTap.DataLibrary.Data.School(Model.SchoolId).GetSpecialFeeList())
                        {
                            <tr>
                                <td>
                                    <span style="margin-left: 15px;" class="addpayment-fee-input">@data.FeeName</span>
                                </td>
                                <td style="width:20%; text-align: right;">
                                    <input class="form-control my_form addpayment-fee-input" data-id="@data.FeeId" autocomplete="off" placeholder="Amount" type="number" min="0"/>
                                </td>
                            </tr>
                        }
                       
                        <tr id="append-div-dev"></tr>
                        @*<tr>
                                <td style="font-weight: 700; text-align: center;" colspan="2">
                                    <button class="btn btn-link"><i class="fa fa-plus"></i> Add More</button>
                                </td>
                            </tr>*@
                    </table>

                </div>
            </div>
            <div class="modal-footer" style="padding:13px !important;">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" id="save-add-payment" class="btn pay-now-btn">Add</button>
            </div>}
    </div>
</div>
