    function GetFeeSuggestion(searchText) {
        ClearSchoolSuggestion();
        $.ajax({
            url: '/School/GetFeeSuggestByText/' + searchText,
            type: "GET",
            dataType: 'json',
            global: false,    // this makes sure ajaxStart is not triggered
            success: function (result) {
                if (result.status && result.list.length > 0) {
                    var template = $('#fee-suggest-template').clone().html();
                    $.each(result.list, function (i, val) {
                        var content = template.replace('{{feeId}}', result.list[i].feeId)
                                              .replace('{{feeName}}', result.list[i].feeName)
                        $('#fee-suggestion-ul').append(content);
                        $('#fee-suggestion-ul').children('li').children('a').click(function () {
                            var feeId = $(this).attr('data-id');
                            $('#FeeId').val(feeId);
                            console.log(feeId);
                            var dataweneed = $(this).html();
                            var splitdata = dataweneed.split(","), bv = $(this).html();
                            console.log(splitdata[0]);
                            $('#autoFeeId').val(bv);
                            //  console.log($('#location').val(splitdata[1]));
                            $('#fee-suggestion').hide();
                        });
                    });
                    $('#fee-suggestion').show();
                    //  $('#school-suggestion-no-result').hide();
                }
                else {
                    // $('#school-suggestion-no-result').show();
                    $('#fee-suggestion').hide();
                    // $('#no-result').hide();

                    ClearSchoolSuggestion();
                }
            }
        });
    }
    function ClearSchoolSuggestion() {
        $('#fee-suggestion').hide();
        $('#fee-suggestion-ul').html('');
    }



</script>