                                            <input type="checkbox" checked="checked" class="checkbox-input" data-billType="@fee.DiscountAllowed" data-amount="@fee.Amount" data-feeidd="@fee.FeeId" data-feeGuid="@fee.FeeGuid" data-maxamt="@fee.Amount" data-disc="0" data-prev-billNo="@fee.BillNo" data-fee="@fee.Amount^@fee.FeeId^@fee.FeeGuid^@fee.Amount^0^0^@fee.DiscountAllowed^@fee.From^@fee.BillNo" onchange="AddRemoveFee(this)" data-id="chekIp" />
                                            <span class="checkbox-virtual"></span>
                                        </label>
                                    }
                                }
                            </td>

                            <td>
                                @*-----Fee Name--------*@
                                @fee.FeeName
                            </td>

