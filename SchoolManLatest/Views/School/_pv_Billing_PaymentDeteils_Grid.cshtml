                                        <s>@String.Format("{0:0.00}", fee.Amount)</s>
                                        decimal feeAmount = fee.Amount ?? 0;
                                        decimal afterDisc = feeAmount - commonFeeDiscountInThisStuent;
                                        <div><label>After Discount: </label><input id="txt-amount" type="text" style="text-align: right;" value="@String.Format("{0:0.00}", (afterDisc))" /></div>
                                        isAny = 1;
                                    }
                                    if (isAny == 0)
                                    {
                                        //decimal partialPayment = student.GetCurrentAmountParial(fee.FeeId);

                                        <div @*data-amount="@fee.Amount"*@>
                                            <input id="txt-amount" type="text" style="text-align: right;" value="@String.Format("{0:0.00}", fee.Amount)" />
                                        </div>
                                    }
                                }
                            </td>

                        </tr>
                                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="4" style="text-align:right">
                            Previous Balance
                        </td>
                        <td id="tdBalance" style="text-align: right;background-color: #ffffff;" data-id="@studBalance">
