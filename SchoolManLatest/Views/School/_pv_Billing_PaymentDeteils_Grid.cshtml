                                                    </tr>
                                                    <tr>
                                                        <td colspan="4">
                                                            Total Fee
                                                        </td>
                                                        <td id="tdTotal" style="text-align: right;">
                                                            0.00
                                                        </td>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>
                                        <div class="form-group text-right isHidden" id="div-adv-pay">
                                            <button class="btn btn-peek" id="editCommonPayment" data-toggle="modal" data-target="#modalPaymentEdit"><i class="fa fa-edit"></i> Common Fee Discount</button>
                                            <button class="btn btn-peek" id="editPayment" data-toggle="modal" data-target="#modalPaymentEdit"><i class="fa fa-edit"></i> Special Fee Discount</button>
                                            <button class="btn pay-now-btn" test-unit="test" id="btn-save-bill"><i class="fa fa-save"></i> Save</button>
                                            @*<button class="btn pay-now-btn" id="btn-Print-bill" onclick="printContent('tbAcBill')"><i class="fa fa-print"></i> Print</button>*@
                                        </div>
                                    }
