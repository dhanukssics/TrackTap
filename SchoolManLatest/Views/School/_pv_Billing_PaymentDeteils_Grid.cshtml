                                    {
                                        if (discount.feeId == fee.FeeId && fee.DiscountAllowed == 0)//DiscountAllowed= 0 means the bill is normal ,1 = due bills ,2=fine bills
                                        {
                                            <s>@String.Format("{0:0.00}", fee.Amount)</s>
                                            decimal feeAmount = fee.Amount ?? 0;
                                            decimal dis = discount.discountAmount + commonFeeDiscountInThisStuent;
                                            decimal afterDisc = feeAmount - dis;
                                            //decimal afterDisc = fee.Amount ?? 0 - discount.discountAmount;
                                            if (afterDisc >= 0)
                                            {
                                                <div @*data-amount="@afterDisc"*@><label>After Discount: </label><input id="txt-amount" type="text" style="text-align: right;" value="@String.Format("{0:0.00}", (afterDisc))" /></div>
                                            }
                                            else
                                            {
                                                <div @*data-amount="@afterDisc"*@><label>After Discount: </label><input id="txt-amount" type="text" style="text-align: right;" value="@String.Format("{0:0.00}", fee.Amount)" /></div>
                                            }
                                            isAny = 1;
                                        }
                                    }
                                    if ((discountFee.Count == 0 && discountFee == null && commonFeeDiscountInThisStuent > 0) || (isAny == 0 && commonFeeDiscountInThisStuent > 0))
