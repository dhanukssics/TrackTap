                                        {
                                            decimal nowDis = discount.discountAmount + commonFeeDiscountInThisStuent;
                                            @String.Format("{0:0.00}", nowDis)
                                        }
                                        else
                                        {
                                            @String.Format("{0:0.00}", discount.discountAmount)
                                        }
                                    }
                                }
