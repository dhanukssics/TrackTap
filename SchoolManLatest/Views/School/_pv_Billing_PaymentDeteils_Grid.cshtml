@model TrackTap.Models.FeeModel

@{
    var student = new TrackTap.DataLibrary.Data.Student(Model.SchoolModel.studentId);
    decimal studBalance = student.StudentBalance();
    //var paymentList = student.GetStudentPaymentFees().OrderBy(z => z.DueDate).ToList(); // Archana commented this for Academic year of feeses
    var paymentList = student.GetStudentPaymentFeesWithAcademicYear(Model.AcademicYearId).OrderBy(z => z.DueDate).ToList();
    var discountFee = student.Discount.ToList();
    var commonFeeDiscount = student.GetStudentCommonFeeDiscount().ToList();
}
<input type="hidden" value="@student.SchoolId" id="schoolId" />
<input type="hidden" value="@student.ClassId" id="classId" />
<input type="hidden" value="@student.StudentId" id="studentId" />

<style>
    [data-event=disable] > td:not(:first-child) {
        pointer-events: none;
        opacity: .5;
    }

    [data-event=disable] > td {
        background-color: #f1f1f1 !important;
    }
</style>
<div class="form-group isHidden">
    <h4 style="text-align: right;"><span style="float: left;">Payment Details</span> <button class="btn pay-now-btn" data-toggle="modal" data-target="#modalPayment"><i class="fa fa-plus"></i> Add Payment</button></h4>
</div>
@if (paymentList.Count >= 1)
{
    <input type="hidden" id="hfTotal" />
    <div>
        <div class="table-responsive">
            <table class="table account-table" id="tbAcBill">
                <tr id="thead">
                    <th colspan="2">
                        Particulars
                    </th>
                    <th>
                        Discount
                    </th>
                    <th></th>
                    <th style="width:20%; text-align: right;">
                        Amount
                    </th>
                </tr>
                <tbody id="bodyTable">
                    @foreach (var fee in paymentList)
                    {
                        <tr data-id="tbRowAmount">
                            <td style="width: 10px;">
                                @*-----for check box--------*@
                                @{
                                    var isAny1 = 0;
                                    var checkDiscList = 0;
                                    var commonFeeDis = commonFeeDiscount.Where(x => x.Feeid == fee.FeeId && x.DiscountDate.Month == fee.DueDate.Month && x.DiscountDate.Year == fee.DueDate.Year).FirstOrDefault();
                                    decimal commonFeeDiscountInThisStuent = 0;
                                    if (commonFeeDis != null)
                                    {
                                        commonFeeDiscountInThisStuent = commonFeeDis.DiscountAmount ?? 0;
                                    }
                                    foreach (var discount in discountFee)
                                    {
                                        if (discount.feeId == fee.FeeId && fee.DiscountAllowed == 0)//DiscountAllowed= 0 means the bill is normal ,1 = due bills ,2=fine bills
                                        {
                                            //var afterDisc = fee.Amount - discount.discountAmount;
                                            decimal feeAmount = fee.Amount ?? 0;
                                            decimal dis = discount.discountAmount + commonFeeDiscountInThisStuent;
                                            decimal afterDisc = feeAmount - dis;
                                            <label>
                                                @*<input type="checkbox" checked="checked" class="checkbox-input" data-billType="@fee.DiscountAllowed" data-amount="@afterDisc" data-feeidd="@fee.FeeId" data-feeGuid="@fee.FeeGuid" data-maxamt="@fee.Amount" data-disc="@discount.discountAmount" data-prev-billNo="@fee.BillNo" data-fee="@afterDisc^@fee.FeeId^@fee.FeeGuid^@fee.Amount^@discount.discountAmount^0^@fee.DiscountAllowed^@fee.From^@fee.BillNo" onchange="AddRemoveFee(this)" data-id="chekIp" />*@
                                                @*Archana commended this above line becouse wants to add the discount with exta allowded discount, so discount.discountAmount is read only,
                                                    So change the discount.discountAmount field with my discount amount field*@
                                                <input type="checkbox" checked="checked" class="checkbox-input" data-billType="@fee.DiscountAllowed" data-amount="@afterDisc" data-feeidd="@fee.FeeId" data-feeGuid="@fee.FeeGuid" data-maxamt="@fee.Amount" data-disc="@dis" data-prev-billNo="@fee.BillNo" data-fee="@afterDisc^@fee.FeeId^@fee.FeeGuid^@fee.Amount^@dis^0^@fee.DiscountAllowed^@fee.From^@fee.BillNo" onchange="AddRemoveFee(this)" data-id="chekIp" />
                                                <span class="checkbox-virtual"></span>
                                            </label>
                                            isAny1 = 1;
                                        }
                                    }
                                    if ((discountFee.Count == 0 && discountFee == null && commonFeeDiscountInThisStuent > 0) || (isAny1 == 0 && commonFeeDiscountInThisStuent > 0)) //Archana  extra addded
                                    {
                                        decimal feeAmount = fee.Amount ?? 0;
                                        decimal dis = commonFeeDiscountInThisStuent;
                                        decimal afterDisc = feeAmount - dis;
