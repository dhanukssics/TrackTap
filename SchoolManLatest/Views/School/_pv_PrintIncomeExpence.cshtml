@model TrackTap.Models.DateClass
@{
    var countincome = 1;
    var countexpence = 1;
    DateTime date = Model.Selecteddate;
    // var income = new TrackTap.Data.WebsiteService().IncomelistOnDate(Model.Selecteddate).ToList();
    // var ExpencelistOnDate = new TrackTap.Data.WebsiteService().ExpencelistOnDate(Model.Selecteddate).ToList();
    //var totalexpence = ExpencelistOnDate.Sum(x => x.Amount);
    var balanceBD = new TrackTap.Data.WebsiteService().BalancebdDate(date, Model.SchoolId);

    var CurrentincomeList = new TrackTap.Data.WebsiteService().IncomelistOnDate(date, Model.SchoolId).ToList();
    var totalincome = CurrentincomeList.Sum(x => x.Amount);
    var CurrentExpenceList = new TrackTap.Data.WebsiteService().ExpencelistOnDate(date, Model.SchoolId).ToList();
    var totalexpence = CurrentExpenceList.Sum(x => x.Amount);
    if (balanceBD > 0)
    {
        totalincome = totalincome + balanceBD;
    }
    else if (balanceBD < 0)
    {
        totalexpence = totalexpence + Math.Abs(balanceBD);
    }

    var balance = totalincome - totalexpence;
    var balanceHead = "Balance: ";
    if (balance > 0)
    {
        balanceHead = "Profit: ";
    }
    else if (balance < 0)
    {
        balanceHead = "Loss: ";
    }
    else
    {
        balanceHead = "Balance: ";
    }
}
