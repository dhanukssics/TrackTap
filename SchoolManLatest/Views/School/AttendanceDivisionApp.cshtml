@model TrackTap.Models.SchoolModel
@{
    ViewBag.Title = "Attendance Class";
    var classModel = new TrackTap.PostModel.SchoolClassListPostModel();

    classModel.schoolId = Convert.ToString(Model.schoolId);

    var DivModel = new TrackTap.PostModel.SchoolDivisionListPostModel();

    DivModel.schoolId = Convert.ToString(Model.schoolId);

    var ClassResult = new TrackTap.Repository.SchoolRepository().FullClassList(classModel);

    var ClassList = ClassResult.Item3;

    var bioDivision = new TrackTap.Data.Admin().GetAllAppDivision(Model.schoolId);

    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";

    var flag = 0;
}

<style>
    .ng-click-studentDiscount-details {
        cursor: pointer;
    }

    .box-color {
        background-color: #fff;
        display: block;
        position: relative;
        float: left;
        width: 100%;
        margin-bottom: 15px;
        /*padding-top: 15px;*/
    }

    .head-box {
        margin-top: 0px;
        background-color: #03a9f4;
        padding: 15px;
        margin-left: -15px;
        margin-right: -15px;
        color: #fff;
        font-weight: 700;
    }
</style>

<div class="row">
    <div class="col-md-12">
        <h3 style="margin-bottom: 0px;">Custom Attendance</h3>
        <div id="pv-table">
            <div class="">
                <table class="table custome-table table-student-list">
                    <thead>
                        <tr>
                            <th>
                                Class
                            </th>
                            <th>
                                Division
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cls in ClassList)
                        {
                            DivModel.classId = Convert.ToString(cls.ClassId);
                            var DivisionResult = new TrackTap.Repository.SchoolRepository().FullDivisionList(DivModel);
                            foreach (var div in DivisionResult.Item3)
                            {

                                <tr class="ng-click-studentDiscount-details">
                                    <td>
                                        <label style="margin-right: 10px;">
                                            @foreach (var bio in bioDivision)
                                            {
                                                flag = 0;
                                                if (div.DivisionId == bio.DivisionId)
                                                {
                                                    flag = 1;
                                                    <input id="chkBox-user" class="checkbox-input" type="checkbox" data-id="@div.DivisionId" checked onchange="AddRemoveUser(this)" />
                                                    break;
                                                }
                                            }
                                            @if (flag == 0)
                                            {
                                                <input id="chkBox-user" class="checkbox-input" type="checkbox" data-id="@div.DivisionId" onchange="AddRemoveUser(this)" />
                                            }
                                            <span class="checkbox-virtual"></span>
                                        </label>
                                        @div.ClassName
                                    </td>
                                    <td>
                                        @div.DivisionName
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="form-group text-right">
                @*<button class="btn pay-now-btn" data-toggle="modal" data-target="#modalStudent"><i class="fa fa-plus"></i> Add Student</button>*@
                <button class="btn pay-now-btn" data-toggle="modal" id="saveDiscount"><i class="fa fa-save"></i> Save </button>
            </div>
        </div>
    </div><!-- end of col md 12 -->
</div>

