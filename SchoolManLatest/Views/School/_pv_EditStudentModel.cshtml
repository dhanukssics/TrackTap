@model TrackTap.Models.EditStudentModel
@{



}

<div class="modal-dialog" role="document" style="background-color: #fff;">
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title" id="myModalLabel">Edit Student</h4>
        </div>
    </div>
    @using (Ajax.BeginForm("EditStudent", "School", null, new AjaxOptions
    {
        HttpMethod = "POST",
        OnSuccess = "EditStudentSuccess",
        OnFailure = "EditStudentFailed",
    }, new { id = "form-login" }))
    {
        <div class="modal-body">
            <div class="row">
                <div class="col-sm-6">
                    <div class="text-center">
                        <label>Upload Profile Picture</label>
                        <div id="dummyId"></div>
                        @Html.TextBoxFor(m => m.profilePic, new { type = "hidden" })
                        @Html.TextBoxFor(m => m.studentId, new { type = "hidden" })
                        @Html.TextBoxFor(m => m.BusId, new { type = "hidden" })
                        @Html.TextBoxFor(m => m.divisionId, new { type = "hidden" })
                        @Html.TextBoxFor(m => m.classId, new { type = "hidden" })
                        @Html.TextBoxFor(m => m.bloodGroup, new { type = "hidden" })


                        @if (Model.filePath == null || Model.filePath == string.Empty)
                        {
                            <div class="upload-box" id="file_preview_grid_edit" style="background-image: url(../Content/img/default-placeholder-1024x1024-960x960.png);">
                                <input id="default-editpic-browse" type="file" class="uploder-controler" />
                            </div>
                        }
                        else
                        {
                            <div class="upload-box" id="file_preview_grid_edit" style="background-image:url(@Model.filePath);">
                                <input id="default-editpic-browse" type="file" class="uploder-controler" />
                            </div>
                        }
                    </div>
                    <div class="form-group">
                        <label>Name</label>
                        @Html.TextBoxFor(m => m.studentName, new { @class = "form-control", placeholder = "Name" })
                        @Html.ValidationMessageFor(m => m.studentName) 
                    </div>
                    <div class="form-group">
                        <label>Parent Name</label>
                        @Html.TextBoxFor(m => m.parentName, new { @class = "form-control", placeholder = "Parent Name" })
                        @Html.ValidationMessageFor(m => m.parentName)
                    </div>
                    <div class="form-group">
                        <label>Parent Email</label>
                        @Html.TextBoxFor(m => m.parentEmail, new { @class = "form-control", placeholder = "Parent Email" })
                        @Html.ValidationMessageFor(m => m.parentEmail)
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        @Html.TextAreaFor(m => m.address, new { @class = "form-control", placeholder = "Address" })
                        @Html.ValidationMessageFor(m => m.address)
                    </div>

                @*DOB edit new archana*@ 
                    <div class="form-group">
                        <label>DOB</label>
                        <div class="calendar-inp pos_icon_adj ">
                            <i class="fa fa-calendar" style="margin-left: 90%;"></i>
                            @Html.TextBoxFor(m => m.DOBstring, new { @class = "form-control dob-get-data-cls ", placeholder = "" })
                            @Html.ValidationMessageFor(m => m.DOBstring)
                        </div>
                    </div>

                    @*DOB edit new archana*@
                     
                </div><!-- col-sm-6 End -->
                <div class="col-sm-6">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>State</label>
                                @Html.TextBoxFor(m => m.state, new { @class = "form-control", placeholder = "State" })
                                @Html.ValidationMessageFor(m => m.state)
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>City</label>
                                @Html.TextBoxFor(m => m.city, new { @class = "form-control", placeholder = "City" })
                                @Html.ValidationMessageFor(m => m.city)
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Class</label>
                                @Html.TextBoxFor(m => m.className, new { @class = "form-control", placeholder = "Classname", @readonly = "readonly" })
                                @*  @Html.DropDownListFor(m => m.classId, TrackTap.DataLibrary.Data.DropdownData.GetClasses(Model.schoolId), "--Choose--", new { @class = "form-control pv_class-drop-down", @data_live_search = "true" })*@
                                @Html.ValidationMessageFor(m => m.classId)
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Division</label>

                                @*@Html.DropDownListFor(m => m.divisionId, new SelectList(
                                    new List<Object>{
                                         new { value = 0 , text = "--select division--"  }
                                      },
                                    "value",
                                    "text"
                                     ), new { @class = "form-control", @data_live_search = "true", @disabled = "disabled" })*@
                                @Html.TextBoxFor(m => m.division, new { @class = "form-control", placeholder = "Division", @readonly = "readonly" })
                                @Html.ValidationMessageFor(m => m.divisionId)

                                @*<select id="pv_division-drop-down" class="form-control" disabled>
                                        <option>-- Please select division --</option>
                                    </select>
                                    @Html.TextBoxFor(m => m.divisionId, new { type = "hidden" })*@
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Blood Group</label>
                                <select class="form-control" id="slct-bloodGroup">
                                    <option value="">--Choose--</option>
                                    <option value="O−">O−</option>
                                    <option value="O+">O+</option>
                                    <option value="A-">A-</option>
                                    <option value="A+">A+</option>
                                    <option value="B-">B-</option>
                                    <option value="B+">B+</option>
                                    <option value="AB-">AB-</option>
                                    <option value="AB+">AB+</option>

                                </select>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>Gender</label>
                                <div style=" margin-top: 5px;">
                                    @Html.RadioButtonFor(x => x.gender, "M", new { type = "radio", name = "radiog_lite", id = "radio2", @class = "form-group", @checked = "checked" })
                                    <span for="radio2" style="color: black;">Male</span>
                                    @Html.ValidationMessageFor(m => m.gender)

                                    @Html.RadioButtonFor(x => x.gender, "F", new { type = "radio", name = "radiog_lite", id = "radio1", @class = "form-group" })
                                    <span for="radio1" style="color: black;">Female</span>
                                    @Html.ValidationMessageFor(m => m.gender)
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Contact No.</label>
                        @Html.TextBoxFor(m => m.contactNo, new { @class = "form-control", placeholder = "Contact No." })
                        @Html.ValidationMessageFor(m => m.contactNo)
                    </div>
                    <div class="form-group">
                        <label>Admission No.</label>
                        @Html.TextBoxFor(m => m.admissionNo, new { @class = "form-control", id = "studentAdmissionNo", placeholder = "Admission No." })
                        <span id="spn-error-admissionNo" data-val="0" data-myval="10" style="color:red;"></span>
                        @Html.ValidationMessageFor(m => m.admissionNo)
                    </div>
                    <div class="form-group">
                        <label>Bus Name</label>
                        @Html.DropDownListFor(m => m.BusId, TrackTap.DataLibrary.Data.DropdownData.GetBusName(Model.schoolId), "--Select Bus--", new { @class = "form-control pv_bus-drop-down" })
                    </div>
                    <div class="form-group">
                        <label>Trip Number</label>
                        @Html.TextBoxFor(m => m.tripNumber, new { @class = "form-control", placeholder = "Trip Number" })
                    </div>
                    <div class="form-group">
                        <label>RF Card Number</label>
                        @Html.TextBoxFor(m => m.biometricId, new { @class = "form-control", placeholder = "Card Number" })
                    </div>
                </div>
            </div>

        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
            <button class="btn pay-now-btn" id="studentStudentAdd">Save</button>
        </div>
    }
</div>

<script>
    $(document).ready(function () {
        var grp = $("#bloodGroup").val();
        $('select[id^="slct-bloodGroup"] option[Value="' + grp + '"]').attr("selected", "selected");
    });
    $(document).on('change', '.pv_bus-drop-down', function () {
        $("#BusId").val($(".pv_bus-drop-down option:selected").val());
    });
    //$('#DOBstring').datepicker({
    $('.dob-get-data-cls').datepicker({
        format: "dd-mm-yyyy",
        autoclose: true,
        todayHighlight: true,
        //startDate: '-3d'
        endDate: '+d'
    });
    //$('#DOBstring').datepicker({
    //    format: "dd-mm-yyyy",
    //    autoclose: true,
    //    todayHighlight: true,
    //    //startDate: '-3d'
    //    endDate: '+d'
    //});

    $(document).on('keyup', '#studentAdmissionNo', function () { //Archana : For check admission number 09-Aug-17
        var studentId = $('#studentId').val();
        var source = $(this);
        var id = studentId + '~' + $(source).val();
        $.ajax({
            url: '/School/CheckAdmissionNoEdit?text=' + id,
            type: "GET",
            global: false,     // this makes sure ajaxStart is not triggered
            dataType: 'json',
            success: function (data) {
                if (data.Status) {
                    $('#spn-error-admissionNo').text(data.Message);
                    $('#ValidateForm').val(true);
                    $('#spn-error-admissionNo').show();
                    $('#studentStudentAdd').css({ 'cursor': 'default', 'pointer-events': 'none', 'opacity': '.8' }); //Avoid Save Buttion Click Vishnu-Button
                }
                else {
                    $('#ValidateForm').val(false);
                    $('#spn-error-admissionNo').hide();
                    $('#studentStudentAdd').css({ 'cursor': 'pointer', 'pointer-events': 'initial', 'opacity': '1' });
                }
            }
        });

    });
</script>