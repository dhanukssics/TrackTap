                        @*  <p><b>Comming Soon</b></p>*@
                        <table class="table table-no-border text-center table-text-center">
                            <thead>
                                <tr>
                                    <th>Class</th>
                                    <th>Division</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (feeCollectionHome.Count() >= 1)
                                {

                                    foreach (var data in feeCollectionHome)
                                    {

                                        <tr>
                                            <td>@data.Class</td>
                                            <td>@data.Division</td>
                                            <td>@String.Format("{0:0.00}", data.Amount)</td>
                                        </tr>
                                    }
                                    <tr>
                                        <td colspan="2"><b class="ttl-strgth">Total Amount</b></td>
                                        <td><b>@String.Format("{0:0.00}", feeCollectionHome.Sum(o => o.Amount))</b></td>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td>NA</td>
                                        <td>NA</td>
                                        <td>NA</td>
                                    </tr>
                                    <tr>
                                        <td colspan="2"><b class="ttl-strgth">Total Amount</b></td>
                                        <td><b>0</b></td>
                                    </tr>
                                }


                            </tbody>
