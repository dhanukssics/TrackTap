<script>
    $(document).ready(function () {
        var totAtnd = $('#hfTotAtnd').val();
        var totStudent = $('#hfTodayTotStr').val();
        $('#tot-pie-atnd').html(totAtnd);
        var per = (parseInt(totAtnd) / parseInt(totStudent)) * 100;
        var roundPer = Math.ceil(per);
        console.log(per);
        console.log(roundPer);
        if ((totAtnd == 0) && (totStudent == 0)) {
            $('#pie-per-atnd').html("0%");
        }
        else {
            $('#pie-per-atnd').html(parseInt(roundPer) + "%");
        }
    });
    //function EventView() {
    $(document).on('click', '.event-dev', function () {
        //debugger;
        //var id = $('#event-id').val();
        var id = $(this).attr('data-id');
        console.log(id);
        $.ajax({
            url: '/School/UpcomingEventView/' + id,
            dataType: 'html',
            success: function (data) {
                $('#modalEventView').html('');
                $('#modalEventView').html(data);
                $('#modalEventView').modal('show');
            },
        });
    });
</script>