                    @{
                        var currenttime = new TrackTap.Controllers.BaseController().CurrentTime;
                        var school = new TrackTap.Data.School(Model.schoolId);
                        var classes = school.Divisions.Where(z => z.Class.PublishStatus == true).ToList().OrderBy(z => z.Class.ClassOrder);
                        var schoolAtnd = 0;
                        var totStudent = 0;
                        var todayTotStrength = 0;
                        var feeCollectionHome = school.GetDailyFeeCollectionHome().ToList().OrderBy(z => z.ClassOrder);
                        var libraryBookHome = school.GetLibraryBookountHome().ToList().OrderBy(z => z.Category);

                    }
                    <div class="table-responsive">
                        <table class="table table-no-border text-center table-text-center">
                            <thead>
                                <tr>
                                    <th>Class</th>
                                    <th>Division</th>
                                    <th>Strength</th>
                                    <th>Attendance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var clas in classes)
                                {
                                    var divisionDetail = new TrackTap.Data.Division(clas.DivisionId);
                                    var attendance = divisionDetail.GetAttendanceCount(0).ToList();
                                    var strength = divisionDetail.GetStudentCount();
                                    //var totCount = attendance.Count;
                                    var present = attendance.Where(z => z.AttendanceData == true).ToList().Count();
                                    schoolAtnd = schoolAtnd + present;
                                    totStudent = totStudent + strength;
                                    <tr>
                                        <td>@clas.ClassName</td>
                                        <td>@clas.DivisionName</td>
                                        <td>@strength</td>

                                        @if (present != 0)
                                        {
                                            <td>@present</td>
                                            todayTotStrength = todayTotStrength + strength;
                                        }
                                        else
                                        {
                                            <td>Not Taken</td>
                                        }
                                    </tr>
                                }
                                <tr>
                                    <td colspan="2"><b class="ttl-strgth">Total Strength</b></td>
                                    <td><b>@totStudent</b></td>
                                    <td><b>@schoolAtnd</b></td>
                                    <input type="hidden" value="@schoolAtnd" id="hfTotAtnd" />
                                    <input type="hidden" value="@totStudent" id="hfTotStud" />
                                    <input type="hidden" value="@todayTotStrength" id="hfTodayTotStr" />

                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

            <div class="col-lg-6 col-md-6 col-sm-6 col-xs-12">
                <div class="pan">
                    <div class="head-pan">
                        Fee Collection
                    </div>
                    @*<div class="body-pan">
