@model TrackTap.Models.SchoolModel
@{
    ViewBag.Title = "Income And Expenditure";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";

    var incomeAndExp = new TrackTap.Data.School(Model.schoolId).GetIncomeAndExpenditure();
    //var exp = incomeAndExp.Where(z => z.accountType == 5).ToList();
    //var inc = incomeAndExp.Where(z => z.accountType == 6).ToList();
    //var count = exp.Count >= inc.Count ? exp.Count : inc.Count;
}

@*<style>
        .ng-teacherDetails-click {
            cursor: pointer;
        }
    </style>*@
<style>
    .slash {
        content: '/';
    }
</style>
<div class="row">
    <div class="form-group text-center">
        <button class="btn pay-now-btn" id="btn-Print-bill" onclick="printContent('print-inc-exp')"><i class="fa fa-print"></i> Print</button>

        <button class="btn pay-now-btn" id="btn-excel-inc-exp"><i class="fa fa-table"></i> Excel</button>
        <input id="todatDate" type="hidden" value="@Model.curredntDateTime.ToString("dd-MMM-yyyy")" />

    </div>
</div>
<div class="row">
    <div class="col-md-12" id="print-inc-exp">
        <h3>Income And Expenditure Account as on @Model.curredntDateTime.ToString("dd-MMM-yyyy")</h3>


        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="table-responsive" style="padding: 0px 50px 0px 50px;">
                    <div class="row" style="background: #fff; padding: 0; margin: 0;">
                        <div>
                            <table class="table custome-table table-bordered" id="table-inc-exp" style="margin-bottom:0px;width:100%">
                                <thead>
                                    <tr>
                                        @*<th style="width: 5%;">
                                                Slno
                                            </th>*@
                                        <th style="width: 34%;">
                                            Expenditure
                                        </th>
                                        <th style="text-align: center;  width: 13%;">
                                            Amount
                                        </th>
                                        <th style="width: 34%;">
                                            Income
                                        </th>
                                        <th style="text-align: center;  width: 13%;">
                                            Amount
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        int i = 1;
                                        foreach (var item in incomeAndExp)
                                        {
                                            var expbal = item.ExpenditureAmount == "" ? "0" : item.ExpenditureAmount;
                                            var incbal = item.IncomeAmount == "" ? "0" : item.IncomeAmount;
                                            <tr>
                                                <td>
                                                    @item.Expenditure
                                                </td>
                                                <td style="text-align: right;">
                                                    <span class="span-exp" data-amt="@expbal"> @string.Format("{0:0.00}", item.ExpenditureAmount)</span>
                                                </td>
                                                <td>
                                                    @item.Income
                                                </td>
                                                <td style="text-align: right;">
                                                    <span class="span-inc" data-amt="@incbal"> @string.Format("{0:0.00}", item.IncomeAmount)</span>
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                                <tfoot>
                                        <tr style="font-weight:bold">
                                            <td>Total</td>
                                            <td id="tdExpTotal" style="text-align: right;"></td>
                                            <td>Total</td>
                                            <td id="tdIncTotal" style="text-align: right;"></td>
                                    </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @*<div class="row" style="padding: 0px 60px 0px 60px; margin-top: -25px;">
            <div class="col-md-6">
                <h4 id="tdExpTotal" class="text-right">Total</h4>
            </div>
            <div class="col-md-6">
                <h4 id="tdIncTotal" class="pull-right">Total</h4>
            </div>
        </div>*@
    </div><!-- end of col md 12 -->
</div>




<script>

    $(document).ready(function () {
        sumTotal();
    });
    function sumTotal() {
        //alert();
        var Aval = 0;
        $('.span-inc').each(function () {
            Aval = parseFloat(Aval) + parseFloat($(this).attr('data-amt'));
        });
        $('#tdIncTotal').html(parseFloat(Aval));

        var Lval = 0;
        $('.span-exp').each(function () {
            Lval = parseFloat(Lval) + parseFloat($(this).attr('data-amt'));
            console.log(Lval);
        });
        $('#tdExpTotal').html(parseFloat(Lval));
        console.log(Lval);
    }
    function printContent(el) {
        var restorepage = document.body.innerHTML;
        var printcontent = document.getElementById(el).innerHTML;
        document.body.innerHTML = printcontent;
        window.print();
        document.body.innerHTML = restorepage;
        //   var id =@Model.Selecteddate
        //    window.location.href = '/School/Report';
    }

    $(document).on('click', '#btn-excel-inc-exp', function () {
        var date = $('#todatDate').val();
        $("#table-inc-exp").table2excel({
            name: "Table2Excel",
            filename: "Income & Expenditure a_c as on " + date,
            fileext: ".xls"
        });
    });
</script>
