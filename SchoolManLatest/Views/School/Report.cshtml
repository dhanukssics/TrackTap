    $(document).on('keydown', ".in-amount", function (e) {
        // Allow: backspace, delete, tab, escape, enter and .
        if ($.inArray(e.keyCode, [46, 8, 9, 27, 13, 110, 190]) !== -1 ||
            // Allow: Ctrl+A, Command+A
            (e.keyCode === 65 && (e.ctrlKey === true || e.metaKey === true)) ||
            // Allow: home, end, left, right, down, up
            (e.keyCode >= 35 && e.keyCode <= 40)) {
            // let it happen, don't do anything
            return;
        }
        // Ensure that it is a number and stop the keypress
        if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {
            e.preventDefault();
        }
    });

    $(document).on('keydown', ".ex-amount", function (e) {
        // Allow: backspace, delete, tab, escape, enter and .
        if ($.inArray(e.keyCode, [46, 8, 9, 27, 13, 110, 190]) !== -1 ||
            // Allow: Ctrl+A, Command+A
            (e.keyCode === 65 && (e.ctrlKey === true || e.metaKey === true)) ||
            // Allow: home, end, left, right, down, up
            (e.keyCode >= 35 && e.keyCode <= 40)) {
            // let it happen, don't do anything
            return;
        }
        // Ensure that it is a number and stop the keypress
        if ((e.shiftKey || (e.keyCode < 48 || e.keyCode > 57)) && (e.keyCode < 96 || e.keyCode > 105)) {
            e.preventDefault();
        }
    });

    $(document).on('keyup', '.td-submit-row-expnce', function (event) {

        var newsource = $(this);
        var status = true;
        var Date = $('#selecteddate').val();

        var headValue = $(newsource).parent().find('.ex-account-head').val();
        var particularValue = $(newsource).parent().find('.ex-particular').val();
        var amount = $(newsource).parent().find('.ex-amount').val();

        var obj = new Object();
        obj.HeadValue = headValue;
        obj.ParticularValue = particularValue;
        obj.Amount = amount;
        var res = Date.split("-");
        var dd = res[0];
        var mm = res[1];
        var yyyy = res[2];
        var ztoday = mm + '-' + dd + '-' + yyyy;
        obj.SelectedDate = ztoday;
        if (Date == "") {

            $('#selecteddate').addClass('empty_field')
        }
        else {
            $('#selecteddate').removeClass('empty_field')

        }
        if (headValue == "") {
            $(newsource).parent().find('.ex-account-head').addClass('empty_field')
        }
        else {
            $(newsource).parent().find('.ex-account-head').removeClass('empty_field')

        }
        if (particularValue == "") {
            $(newsource).parent().find('.ex-particular').addClass('empty_field')
        }
        else {
            $(newsource).parent().find('.ex-particular').removeClass('empty_field')

        }
        if (amount == "") {
            $(newsource).parent().find('.ex-amount').addClass('empty_field')
        }
        else {
            $(newsource).parent().find('.ex-amount').removeClass('empty_field')

        }
        if (headValue != "" && particularValue != "" && amount != "" && Date != "") {
            var keycode = (event.keyCode ? event.keyCode : event.which);
            var hdnenter = $(newsource).parent().find('#hdn-enter-expence').val();
            //console.log(hdnenter)
            if (hdnenter == 0) {
                if (keycode == '13') {
                    $(newsource).parent().find('#hdn-enter-expence').val(1)
                    $.ajax({
                        url: '/School/SubmitExpenceData',
                        type: "POST",
                        dataType: 'json',
                        global: false,
                        data: obj,
                        success: function (data) {
                            if (data.message = "success") {
                                var totalex = $('#expn').val();
                                var finaltotal = parseFloat(totalex) + parseFloat(amount);
                                $('#expn').val(finaltotal)
                                $('#newexpnce').html(finaltotal)
                                var bal = parseFloat($('#income').val()) - finaltotal;
                                $('#newbalance').html(bal);
                                if (bal > 0) {
                                    $('#balance-span-dev').html("Profit: ");
                                }
                                else if (bal < 0) {
                                    $('#balance-span-dev').html("Loss: ");
                                }
                                else {
                                    $('#balance-span-dev').html("Balance: ");
                                }


                                var template = $('#expence-list-append-template').clone().html();
                                //console.log(template)
                                $('.expence').append(template);
                                var hiddenvalue = $('#hidden-expence').val();
                                var s = $('#expence-table tr:last').children("td:first").replaceWith('<td class="slno">' + parseInt(parseInt(hiddenvalue) + parseInt(1)) + '</td>');
                                //.find('.slno').replaceWith('<td class="slno">' + parseInt(hiddenvalue) + parseInt(1) + '</td>');
                                $('#hidden-expence').val(parseInt(parseInt(hiddenvalue) + parseInt(1)));
                                $(newsource).parent().find('.td-submit-row-expnce').removeClass('td-submit-row-expnce').addClass('td-submit-row-expnce-edit')

                                $(newsource).parent().find('.ex-amount').addClass('isPointer')
                                $(newsource).parent().find('.ex-account-head').addClass('isPointer')
                                $(newsource).parent().find('.ex-particular').addClass('isPointer')
                                $(newsource).parent().append('<td><a class="isClass"><i class="fa fa-pencil-square-o edit-expence"></i></a></td>')

                                $('#hdn-value-ex-head').val(headValue);
                                $('#hdn-value-ex-parti').val(particularValue);
                                RefreshExpenceAccountSearchHead();
                                setTimeout(function () {
                                    newsource.parent().parent().find('.ex-account-head').last().focus();
                                }, 1000);

                            }
                            else {
                                $(newsource).parent().find('#hdn-enter-expence').val(0)


                            }
                        }
                    });

                    RefreshExpenceAccountSearchHead();
                }
            }
            //
        }

    });
    $(document).on('keyup', '.td-submit-row', function (event) {
        // console.log(100)
        //$('#hdn-value-in-head').val('');
        //$('#hdn-value-in-parti').val('');

