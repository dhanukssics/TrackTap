    $(document).on('keyup', '.td-submit-row-edit', function (event) {
        var newsource = $(this);
        var Id = newsource.parent().attr('data-id');
        var status = true;
        var headValue = $(newsource).parent().find('.in-account-head').val();
        var particularValue = $(newsource).parent().find('.in-particular').val();
        var amount = $(newsource).parent().find('.in-amount').val();
        var Date = $('#selecteddate').val();

        var obj = new Object();
        obj.HeadValue = headValue;
        obj.ParticularValue = particularValue;
        obj.Amount = amount;
        var res = Date.split("-");
        var dd = res[0];
        var mm = res[1];
        var yyyy = res[2];
        var ztoday = mm + '-' + dd + '-' + yyyy;
        obj.SelectedDate = ztoday;
        obj.Id = Id;
        // console.log(amount)
        if (Date == "") {

            $('#selecteddate').addClass('empty_field')
        }
        else {
            $('#selecteddate').removeClass('empty_field')

        }
        if (headValue == "") {
            $(newsource).parent().find('.in-account-head').addClass('empty_field')
        }
        else {
            $(newsource).parent().find('.in-account-head').removeClass('empty_field')

        }
        if (particularValue == "") {
            $(newsource).parent().find('.in-particular').addClass('empty_field')
        }
        else {
            $(newsource).parent().find('.in-particular').removeClass('empty_field')

        }
        if (amount == "") {
            $(newsource).parent().find('.in-amount').addClass('empty_field')
        }
        else {
            // $('#income').val('');
            $(newsource).parent().find('.in-amount').removeClass('empty_field')

        }
        if (headValue != "" && particularValue != "" && amount != "" && Date != "") {
            var keycode = (event.keyCode ? event.keyCode : event.which);
            if (keycode == '13') {
                $.ajax({
                    url: '/School/SubmitIncomeDataEdit',
                    type: "POST",
                    dataType: 'json',
                    global: false,
                    data: obj,
                    success: function (data) {
                        $(newsource).parent().find('.in-account-head').addClass('isPointer')
                        $(newsource).parent().find('.in-particular').addClass('isPointer')
                        $(newsource).parent().find('.in-amount').addClass('isPointer')
                        $(newsource).parent().find('.edit-income').show()

                        $(newsource).find('.in-amount').blur();
                        newsource.parent().parent().find('.in-account-head').last().focus()

                        var totalinc = $('#income').val();
                        var prevamout = data.Amount;
                        //console.log(data.Amount)
                        var finaltotal = parseFloat(totalinc) + parseFloat(amount) - prevamout;
                        $('#income').val(finaltotal)
                        $('#newincome').html(finaltotal)

                        var bal = finaltotal - parseFloat($('#expn').val());
                        $('#newbalance').html(bal);
                        if (bal > 0) {
                            $('#balance-span-dev').html("Profit: ");
                        }
                        else if (bal < 0) {
                            $('#balance-span-dev').html("Loss: ");
                        }
                        else {
                            $('#balance-span-dev').html("Balance: ");
                        }
                    }
                });
            }
        }
    });

