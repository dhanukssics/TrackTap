    $(document).on('change', '#selecteddate', function () {
        var datess = $('#selecteddate').val();
        var today = new Date();
        var dd = today.getDate();
        var mm = today.getMonth() + 1;
        var yyyy = today.getFullYear();
        if (dd < 10) {
            dd = '0' + dd
        }

        if (mm < 10) {
            mm = '0' + mm
        }
        var today = dd + '-' + mm + '-' + yyyy;

        var res = datess.split("-");
        var dd = res[0];
        var mm = res[1];
        var yyyy = res[2];
        var ztoday = mm + '-' + dd + '-' + yyyy;
        if (datess == today) {
            //console.log(today + "     ...         " + datess);
            window.location.href = "/School/Report/";
        }
        else {
            $.ajax({
                url: '/School/GetAllReportOnDate/' + ztoday,
                type: "GET",
                dataType: 'html',
                global: false,
                success: function (data) {
                    RefreshAllAccountSearchHead();
                    $('#divpartial').html('');
                    $('#divpartial').html(data);

                }
            });
        }


    });

