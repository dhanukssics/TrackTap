    $(document).on('click', '.btn-Cancel', function () {
        debugger;
        var source = $(this);
        swal({
            title: "Are you sure?",
            text: "You will not be able to undo this !",
            type: "warning",
            showCancelButton: true,
            confirmButtonColor: "#DD6B55",
            confirmButtonText: "Yes, Cancel Bill!",
            cancelButtonText: "No, Leave it!",
            closeOnConfirm: true,
            closeOnCancel: true
        },
function (isConfirm) {
    if (isConfirm) {
        //cancel = 1;
        //$.ajax({
        //    url: '/School/CancelBill/' + $('#excel-head-bill').val() + '~' + $('#excel-studentId').val(),
        //    type: "GET",
        //    dataType: 'json',
        //    success: function (data) {
        //        if (data.status) {
        //            toastrSuccess(data.msg);
        //            window.location.href = '/School/CollectionReport';
        //        }
        //        else {
