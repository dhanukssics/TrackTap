@model TrackTap.Models.FeeModel
@{
    ViewBag.Title = "Student";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
    var student = new TrackTap.DataLibrary.Data.Student(Model.StudentId);
    var historyBills = student.GetHistoryTableByBillNo(Model.BillNumber);
    var studentPaidFee = student.StudentPaidAmountByBillNo(Model.BillNumber);
    var x = 0;
}

<style>
    span {
        color: red;
    }
</style>
<input type="hidden" value="@student.StudentId" id="excel-studentId" />
<input type="hidden" value="@student.StundentName" id="excel-head-student" />
<input type="hidden" value="@student.ClassName" id="excel-head-class" />
<input type="hidden" value="@student.DivisionName" id="excel-head-division" />
<input type="hidden" value="@Model.BillNumber" id="excel-head-bill" />
<div class="row" id="print-report-full">
    <div class="col-md-12">
        @*<h3 style="margin-top: 5px; margin-bottom: 15px; text-align:center;">Bill Detailed Report</h3>
        <div>*@
            @*<table style="width: 100%; margin-bottom: 20px;" border="0" cellpadding="0" cellspacing="0">
                <tr>
                    <td>
