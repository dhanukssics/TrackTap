                    </td>
                    <td>
                        <label>Bill Number : </label> @Model.BillNumber
                    </td>
                </tr>
                <tr>
                    <td>
                        <label> Parent : </label> @student.ParentName
                    </td>
                    <td>
                        <label>Contact : </label> @student.ContactNumber
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-info btn-print" onclick="printContent('print-report-full')">Print </button>
                        <button type="button" class="btn btn-sm btn-info btn-Cancel">Cancel</button>
                    </td>
                </tr>
            </table>*@
        @*</div>*@

        <table style="width: 100%; margin-bottom: 20px;" border="0" cellpadding="0" cellspacing="0">
            <tr>
                <td colspan="3" class="text-center" style="border-bottom: 3px solid #8a8787;">
                    @if (student.School.FilePath != null)
                    {
                        <div class="frmHeader" style="margin:auto; display:table;">
                            <img src="@student.School.FilePath" width="90" style="position: absolute;  left: 25%; margin-right: 5px;" />
                            <div style="text-align:center;">
                                <h1>@student.SchoolName</h1>
                                <h4>@student.SchoolAddress</h4>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="frmHeader" style="width:100%; text-align:center; margin:auto; display:table;">
                            <h1>@student.SchoolName</h1>
                            <h4>@student.SchoolAddress</h4>
                        </div>

                    }
                </td>
            </tr>
            <tr>
                <td style="text-align:center; padding-top: 10px;font-size: 20px;" colspan="3">
                    <label>FEE RECEIPT </label>
                </td>

            </tr>
            <tr>
                <td >
                    <label>Student Name : </label> @student.StundentName
                </td>
                <td >
                    <label>Class & Division :  </label> @student.ClassName @student.DivisionName
                </td>
                <td>
                    <label>Bill Number : </label> @Model.BillNumber
                </td>
            </tr>
            <tr>
                <td >
                    <label>Parent : </label> @student.ParentName
                </td>
                <td>
                    <label>Contact : </label> @student.ContactNumber
                </td>
                <td>
                    <button type="button" class="btn btn-sm btn-info btn-print" onclick="printContent('print-report-full')">Print </button>
                    <button type="button" class="btn btn-sm btn-info btn-Cancel">Cancel</button>
                </td>
            </tr>
        </table>





        <div id="pv-table">
            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Sl No</th>
                            <th>Particulars</th>
                            <th>Discount</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{var index = 1;
            decimal sum = 0;}
                        @foreach (var historyBill in historyBills)
            {
                            <tr>
                                <td>@index</td>
                                @try
                {
                    if (historyBill.FeeClass.DueDate != null)
                    {
                                        <td>@historyBill.Fee.FeeName @String.Format("{0:y}", historyBill.FeeClass.DueDate)</td>
                                    }
                                }

                                catch (Exception ex)
                                {
                                    bool isThere = student.IsDueBill(historyBill.FeeGuid);
                                    if (isThere)
                                    {
                                        <td>@historyBill.Fee.FeeName Due</td>
                                    }
                                    else
                                    {
                                        <td>@historyBill.Fee.FeeName</td>
                                    }
                                }

                                <td>
                                    @if (historyBill.Discount > 0)
                                    {
                                        @String.Format("{0:0.00}", historyBill.Discount)
                                    }
                                </td>
                                <td>@String.Format("{0:0.00}", historyBill.Amount)</td>
                            </tr>
                            sum = sum + historyBill.Amount;
                            index++;

                        }
                    </tbody>
                    <tfoot>
                        @if (studentPaidFee != null)
            {
                            <tr>
                                <td style="padding: 5px; font-weight: bold;" colspan="2">
                                    Total Fee
                                </td>
                                <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="3">
                                    @String.Format("{0:0.00}", sum)
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 5px; font-weight: bold;" colspan="2">
                                    Previous Balance
                                </td>
                                <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="3">
                                    @String.Format("{0:0.00}", studentPaidFee.PreviousBalance)
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 5px; font-weight: bold;" colspan="2">
                                    Amount Paid
                                </td>
                                <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="3">
                                    @String.Format("{0:0.00}", studentPaidFee.PaidAmount)
                                </td>
                            </tr>

                        }
                        else
                        {

                            <tr>
                                <td style="padding: 5px; font-weight: bold;" colspan="2">
                                    Total Fee
                                </td>
                                <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="3">
                                    @String.Format("{0:0.00}", sum)
                                </td>
                            </tr>
                        }
                    </tfoot>

                    @*<tfoot>
                            <tr>
                                <td style="padding: 5px; font-weight: bold;" colspan="2">
                                    Total Fee
                                </td>
                                <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="3">
                                    @String.Format("{0:0.00}", sum)
                                </td>
                            </tr>
                        </tfoot>*@
                </table>
            </div>
        </div>
    </div><!-- end of col md 12 -->
</div>

<div class="modal fade" id="returnPaymentMode-model" z-index="99999" role="dialog" aria-labelledby="myModalLabel6">

</div>
<!-- Modal -->
<script>
