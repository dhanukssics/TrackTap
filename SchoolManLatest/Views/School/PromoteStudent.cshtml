    $("#promote-student").click(function () {
        var toDivisionId = parseInt($('#division-drop-down-2').val());
        var classId = parseInt($('.slct-class-dropdwn-2').val());
        var divisionId = parseInt($('#division-drop-down').val());
        console.log(divisionId, classId);
        //alert(divisionId);
        if (classId > 0) {
            if (divisionId > 0) {
                var item = new Object();
                item.divisionId = divisionId;
                item.toDivisionId = toDivisionId;
                item.classId = classId;
                item.stringStudentId = array.toString();
                $.post("/School/PremoteStudentClass/", item, function (result) {
                    //console.log(JSON.stringify(result))
                    if (result.status) {
                        toastrSuccess(result.msg);
                        $('#addPromoteClass').modal('hide');
                        //       window.location.href = '/School/FeeDiscount/';
