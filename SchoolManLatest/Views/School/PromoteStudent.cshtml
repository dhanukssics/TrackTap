            }
        }
        else {
            toastrWarning("Please select Class");
        }
    });

    $(document).on('change', '#chkBox-chkAll', function () {
        if ($(this).is(":checked")) {
            $(".chk-stud").prop('checked', true);
        }
        else {
            $(".chk-stud").prop('checked', false);
        }
      
