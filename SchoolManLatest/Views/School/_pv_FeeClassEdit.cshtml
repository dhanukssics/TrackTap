@model TrackTap.Models.EditFeeClass
<div class="modal-dialog modal-sm" role="document">

    <style>
        span {
            color: red;
        }
    </style>

    @using (Ajax.BeginForm("EditFeeClass", "School", null, new AjaxOptions
        {
            HttpMethod = "POST",
            OnSuccess = "EditFeeClassSuccess",
            OnFailure = "ajaxFailure",
        }, new { id = "form-login" }))
    {
        @Html.HiddenFor(z => z.feeClassId, new { Value = @Model.feeClassId })
        @Html.HiddenFor(z => z.feeId, new { Value = @Model.feeId })
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">Edit Feeclass</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>ClassName</label>
                    @Html.TextBoxFor(m => m.classname, new { autocomplete = "off", @readonly = "readonly", placeholder = "", @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>Amount</label>
                    @Html.TextBoxFor(m => m.amount, new { autocomplete = "off", @type = "number", placeholder = "", @class = "form-control" })
                </div>
                <div class="form-group">
                    <label>Due Date</label>
                    @Html.TextBoxFor(m => m.DueDate, "{0:MM/dd/yyyy}", new { autocomplete = "off", placeholder = "Date", @class = "form-control dapicker" })
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button class="btn pay-now-btn">Edit</button>
            </div>
        </div>
    }
</div>
<script>
    $(".dapicker").datepicker();
</script>