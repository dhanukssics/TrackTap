@model TrackTap.Models.FeeModel

@{
    //var historyBills = new TrackTap.Data.Student(Model.SchoolModel.studentId).GetHistoryTableByDate(Model.TimeStamp);
    var student = new TrackTap.Data.Student(Model.SchoolModel.studentId);
    var studentData = student.GetStudentData();
    //var historyBills = student.GetHistoryTableByBillNo(Model.BillNumber);
    var studentPaidFee = student.StudentPaidAmountByBillNo(Model.BillNumber);
    int s = Convert.ToInt32(Session["UserType"]);
    Session["studentid"] = student.StudentId;
    List<TrackTap.Data.Payment> paymentList = student.GetStudentPaidFeesByBillNo(Model.BillNumber);
    var totalAmount = paymentList.Sum(z => z.Amount);
    DateTime paymentDate = paymentList[0].TimeStamp;
    int index = 1;
    var className = paymentList[0].ClassName;
    var divisionName = paymentList[0].DivisionName;
    var x = 0;
}
@*<link href="~/Scripts/print.min.css" rel="stylesheet" />
    <script src="~/Scripts/print.min.js"></script>*@
<style>


    .stud-pare-detls h4, .stud-pare-detls h5 {
        margin-bottom: 15px;
        width: 200px;
        display: inline-block;
    }

    .stud-pare-detls span {
        font-weight: bold;
    }

    .mainTtle {
        margin: auto;
        display: table;
    }

    .logoImg, .logoTtle {
        float: left;
    }

    .logoTtle {
        padding-left: 10px;
    }

    @@media screen {
        #printSection {
            display: none;
        }
    }

    @@media print {
        body * {
            visibility: hidden;
        }

        #printSection, #printSection * {
            visibility: visible;
        }


        #printSection {
            position: absolute;
            left: 0;
            top: 0;
        }
    }



</style>


<div id="History-Print">
    <input type="text" value="@student.StudentId" id="idofstudent" style="display:none;" />
    <input type="text" value=@Model.BillNumber id="billnumber" style="display:none;" />

    <table style="width: 100%; margin-bottom: 20px;" border="0" cellpadding="0" cellspacing="0">
        <tr>
            <td colspan="3" class="text-center" style="border-bottom: 3px solid #8a8787;">
                @*<table style="width: 100%; margin-bottom: 20px; border-bottom: 1px solid #000;" border="0" cellpadding="0" cellspacing="0">
                        <tr>
                            <td style="padding: 15px; text-align:center;">
                                <h2>
                                    @studentData.SchoolName
                                </h2>
                                <h4>
                                    @studentData.SchoolAddress
                                </h4>
                            </td>
                        </tr>
                    </table>*@
                @if (student.School.FilePath != null)
                {
                    <div class="frmHeader" style="margin:auto; display:table;">
                        <img src="@student.School.FilePath" width="90" style="position: absolute; left: 0; margin-right: 5px;border:0;" />
                        <div style="text-align:center;">
                            <h2>@student.SchoolName</h2>
                            <h3>@student.SchoolAddress</h3>
                        </div>
                    </div>
                }
                else
                {
                    <div class="frmHeader" style="width:100%; text-align:center; margin:auto; display:table;">
                        <h1>@student.SchoolName</h1>
                        <h4>@student.SchoolAddress</h4>
                    </div>

                }
            </td>
        </tr>
        <tr>
            <td style="text-align:center; padding-top: 10px;font-size: 20px;" colspan="3">
                <label>FEE RECEIPT </label>
            </td>

        </tr>
        <tr>
            <td style="padding-top:15px;">
                <label>Student Name : </label> @studentData.StundentName
            </td>
            <td style="padding-top:15px;">
                @*<label>Class : </label> @studentData.ClassName*@
                <label>Class : </label> @className /@divisionName
            </td>
            <td style="float: right; padding-top:15px;">
                <label>BillNo : </label> @Model.BillNumber / @paymentDate.Year
            </td>
        </tr>
        <tr>
            <td style="">
                @*<label>Division : </label> @studentData.DivisionName*@
                <label>Adm.No : </label> @studentData.StudentSpecialId
            </td>
            <td style="">
                @*<label>Date : </label> @String.Format("{0:y}", currentData)*@
                <label>Date : </label> @paymentDate.ToString("dd/MM/yyyy") <span style="margin-left:15px;">@paymentDate.ToString("hh:mm tt")</span>
            </td>
            <td style="float:right;">
                <label>Contact : </label> @studentData.ContactNumber
            </td>
        </tr>
    </table>





    <hr style="border-top: 3px solid #8a8787;" />
    <div><p style="text-align: center; font-size: 20px; font-weight: bold;">Fee Details</p></div>
    <table style="width: 100%;" border="1" cellpadding="0" cellspacing="0">
        <thead>
            <tr>
                <th style="padding: 5px; width:20px; ">
                    SlNo
                </th>
                <th style="padding: 5px; text-align: left;">
                    Fees Description
                </th>
                <th style="padding: 5px; text-align: center;">
                    Payable Amount
                </th>
                <th style="width:20px; padding: 5px; ">
                    Discount
                </th>
                <th style="padding: 5px; text-align: center;">
                    Paid Amount
                </th>
                <th style="padding: 5px; text-align: center;">
                    Status
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fee in paymentList)
            {
                <tr>
                    <td style="padding: 5px; text-align: center;">
                        @index
                    </td>

                    @try
                    {
                        if (fee.FeeClass.DueDate != null)
                        {
                            <td style="padding-left: 10px; ">@fee.Fee.FeeName @String.Format("{0:y}", fee.FeeClass.DueDate)</td>
                        }
                    }

                    catch (Exception ex)
                    {
                        bool isThere = student.IsDueBill(fee.FeeGuid);
                        if (isThere)
                        {
                            <td style="padding-left: 10px; ">@fee.Fee.FeeName Due</td>
                        }
                        else
                        {
                            if (fee.BillType == 2)
                            {
                                <td style="padding-left: 10px; ">@fee.Fee.FeeName Fine</td>
                            }
                            else
                            {
                                <td style="padding-left: 10px; ">@fee.Fee.FeeName</td>
                            }
                        }
                    }
                    <td style="padding: 5px; text-align: center;">
                        @String.Format("{0:0.00}", fee.MaxAmount)
                    </td>
                    <td style="padding: 5px; text-align: center;">
                        @if (fee.Discount > 0)
                        {
                            @String.Format("{0:0.00}", fee.Discount)
                        }
                    </td>
                    <td style="padding: 5px; text-align: center;">
                        @String.Format("{0:0.00}", fee.Amount)
                    </td>
                    <td style="padding: 5px; text-align: center;">
                        @{ var discount = fee.Discount;
                            var maxamt = fee.MaxAmount;
                            var amnt = fee.Amount;
                            var stat = (maxamt - discount) - amnt;

                        }
                        @if (stat > 0)
                        {
                            <p> Partially Paid</p>
                        }
                        else
                        {
                            <p>Paid</p>
                        }
                    </td>
                </tr>
                index = index + 1;
            }
        </tbody>
        <tfoot>
            @if (studentPaidFee != null)
            {
                <tr>
                    <td style="padding: 5px; font-weight: bold;" colspan="2">
                        Total Fee
                    </td>
                    <td style="padding: 5px; text-align: center; font-weight: bold;" colspan="1">
                        @String.Format("{0:0.00}", paymentList.Sum(z => z.MaxAmount))
                    </td>
                    <td style="padding: 5px; text-align: center; font-weight: bold;" colspan="3">
                        @String.Format("{0:0.00}", paymentList.Sum(z => z.Amount))
                    </td>
                </tr>
                <tr>
                    <td style="padding: 5px; font-weight: bold;" colspan="2">
                        Previous Credit
                    </td>
                    <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="4">
                        @String.Format("{0:0.00}", studentPaidFee.PreviousBalance)
                    </td>
                </tr>
                <tr>
                    <td style="padding: 5px; font-weight: bold;" colspan="2">
                        Amount Paid
                    </td>

                    <td style="padding: 5px; text-align: right; font-weight: bold;" id="total-paid-amt-wr" data-id="@String.Format("{0:0.00}", studentPaidFee.PaidAmount)" colspan="4">
                        @String.Format("{0:0.00}", studentPaidFee.PaidAmount)
                    </td>
                </tr>
                <tr>
                    <td style="padding: 5px; font-weight: bold;" colspan="2">
                        Available Credit
                    </td>
                    <td style="padding: 5px; text-align: right; font-weight: bold;" colspan="4">
                        @String.Format("{0:0.00}", studentPaidFee.BalanceAmount)
                    </td>
                </tr>

            }
            else
            {
                <tr>
                    <td style="padding: 5px; font-weight: bold;" colspan="2" id="total-paid-amt-wr" data-id="@String.Format("{0:0.00}", paymentList.Sum(z => z.Amount))">
                        Total Fee
                    </td>
                    <td style="padding: 5px; text-align: center; font-weight: bold;" colspan="1">
                        @String.Format("{0:0.00}", paymentList.Sum(z => z.MaxAmount))
                    </td>
                    <td style="padding: 5px; text-align: center; font-weight: bold;" colspan="3">
                        @String.Format("{0:0.00}", paymentList.Sum(z => z.Amount))
                    </td>
                </tr>
            }
        </tfoot>
    </table>

    <div style="margin-top:20px; font-weight:bold;" id="amt-inwrds-main">
        <span>Received Rupees <span id="amt-inwords"></span> </span>
    </div>
    <br />
    <div class="row" style="margin-right:50px; font-weight: bold;">
        <span class="pull-right">Cashier </span>
    </div>
    @if (student.School.FooterMessage != null)
    {
        <br />
        <div class="row" style="text-align:center; font-weight: bold;">
            <span>@student.School.FooterMessage </span>
        </div>
    }
</div>
<div id="myModal" class="modal fade" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="printThis">
                @Html.Partial("~/Views/School/Thermalprintview.cshtml")

            </div>
            <div class="modal-footer">
            </div>
        </div>
    </div>
</div>

<div style="text-align: center; margin-top:25px;">
    @*onclick="printContentHistory('History-Print')"*@
    <button type="button" class="btn btn-sm btn-info btn-search" onclick="printContentHistory('History-Print')" id="billPrint">Print</button>
    @if (student.SchoolId == 40162 || student.SchoolId == 40203)
    {
        <button type="button" class="btn btn-sm btn-info btn-search" id="thermalprint" onclick="print_Thermal('History-Print')">ThermalPrint</button>

    }

    @if ((student.SchoolId == 40162 || student.SchoolId == 40203) && (s != 1))
    {
        <button type="button" class="btn btn-sm btn-danger btn-search" style="margin-left: 1px;display:none;" data-billNo="@Model.BillNumber" data-studentId="@student.StudentId" id="cancelBill">Cancel Bill</button>
    }
    else
    {
        <button type="button" class="btn btn-sm btn-danger btn-search" style="margin-left: 1px;" data-billNo="@Model.BillNumber" data-studentId="@student.StudentId" id="cancelBill">Cancel Bill</button>

    }
</div>


<script>


    function printContentHistory(el) {
        //debugger;
        //var printval = sessionStorage.param1;
        //if (printval == 0) {
        var restorepage = document.body.innerHTML;
        var printcontent = document.getElementById(el).innerHTML;
        document.body.innerHTML = printcontent;
        window.print();
        document.body.innerHTML = restorepage;
        $('#billPrint').toggle(true);
        $('#cancelBill').toggle(true);
        location.reload();
    }

  



    function print_Thermal(els) {
        debugger;
        printElement(document.getElementById("printThis"));
    }
    function printElement(elem) {
        //var domClone = elem.cloneNode(true);

        var $printSection = document.getElementById("printSection");

        if (!$printSection) {
            var $printSection = document.createElement("div");
            $printSection.id = "printSection";
            document.body.appendChild($printSection);
        }

        $printSection.innerHTML = "";
        $printSection.appendChild(elem);
        window.resizeTo('100mm', '200mm');
        window.print();
    }

    $(document).ready(function () {
        var amount = $('#total-paid-amt-wr').attr('data-id');


        if (parseFloat(amount) > 0) {
            var amountData = test_skill(amount)
            $('#amt-inwords').html(amountData);

        }
        else {
            $('#amt-inwrds-main').html("Amount fully paid from previous balance");
        }
    });

    function test_skill(amountt) {
        var amount = "";
        var junkVal = amountt;
        junkVal = Math.floor(junkVal);
        var obStr = new String(junkVal);
        numReversed = obStr.split("");
        actnumber = numReversed.reverse();

        if (Number(junkVal) >= 0) {
        }
        else {
            alert('wrong Number cannot be converted');
            return amount;
        }
        if (Number(junkVal) == 0) {
            //document.getElementById('container').innerHTML=obStr+''+'Rupees Zero Only';
            //return amount;
        }
        if (actnumber.length > 9) {
            alert('Oops!!!! the Number is too big to covertes');
            return amount;
        }

        var iWords = ["Zero", " One", " Two", " Three", " Four", " Five", " Six", " Seven", " Eight", " Nine"];
        var ePlace = ['Ten', ' Eleven', ' Twelve', ' Thirteen', ' Fourteen', ' Fifteen', ' Sixteen', ' Seventeen', ' Eighteen', ' Nineteen'];
        var tensPlace = ['dummy', ' Ten', ' Twenty', ' Thirty', ' Forty', ' Fifty', ' Sixty', ' Seventy', ' Eighty', ' Ninety'];

        var iWordsLength = numReversed.length;
        var totalWords = "";
        var inWords = new Array();
        var finalWord = "";
        j = 0;
        for (i = 0; i < iWordsLength; i++) {
            switch (i) {
                case 0:
                    if (actnumber[i] == 0 || actnumber[i + 1] == 1) {
                        inWords[j] = '';
                    }
                    else {
                        inWords[j] = iWords[actnumber[i]];
                    }
                    inWords[j] = inWords[j] + ' Only';
                    break;
                case 1:
                    tens_complication();
                    break;
                case 2:
                    if (actnumber[i] == 0) {
                        inWords[j] = '';
                    }
                    else if (actnumber[i - 1] != 0 && actnumber[i - 2] != 0) {
                        inWords[j] = iWords[actnumber[i]] + ' Hundred and';
                    }
                    else {
                        inWords[j] = iWords[actnumber[i]] + ' Hundred';
                    }
                    break;
                case 3:
                    if (actnumber[i] == 0 || actnumber[i + 1] == 1) {
                        inWords[j] = '';
                    }
                    else {
                        inWords[j] = iWords[actnumber[i]];
                    }
                    if (actnumber[i + 1] != 0 || actnumber[i] > 0) {
                        inWords[j] = inWords[j] + " Thousand";
                    }
                    break;
                case 4:
                    tens_complication();
                    break;
                case 5:
                    if (actnumber[i] == 0 || actnumber[i + 1] == 1) {
                        inWords[j] = '';
                    }
                    else {
                        inWords[j] = iWords[actnumber[i]];
                    }
                    if (actnumber[i + 1] != 0 || actnumber[i] > 0) {
                        inWords[j] = inWords[j] + " Lakh";
                    }
                    break;
                case 6:
                    tens_complication();
                    break;
                case 7:
                    if (actnumber[i] == 0 || actnumber[i + 1] == 1) {
                        inWords[j] = '';
                    }
                    else {
                        inWords[j] = iWords[actnumber[i]];
                    }
                    inWords[j] = inWords[j] + " Crore";
                    break;
                case 8:
                    tens_complication();
                    break;
                default:
                    break;
            }
            j++;
        }

        function tens_complication() {
            if (actnumber[i] == 0) {
                inWords[j] = '';
            }
            else if (actnumber[i] == 1) {
                inWords[j] = ePlace[actnumber[i - 1]];
            }
            else {
                inWords[j] = tensPlace[actnumber[i]];
            }
        }
        inWords.reverse();
        for (i = 0; i < inWords.length; i++) {
            finalWord += inWords[i];
        }
        amount = finalWord;
        return amount;
    }
</script>