
@model TrackTap.Models.CalendarEventModels

<div class="modal-dialog modal-sm" role="document">

    <style>
        span {
            color: red;
        }
    </style>

    @using (Ajax.BeginForm("EditCalendarEvent", "School", null, new AjaxOptions
    {
        HttpMethod = "POST",
        OnSuccess = "EditEventSuccess",
        OnFailure = "ajaxFailure",
    }, new { id = "form-teacher-add" }))
    {
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="myModalLabel">Edit Event</h4>
            </div>
            @Html.HiddenFor(m => m.eventId)
            <div class="modal-body">
                <div class="form-group">
                    <label>Event Date</label>
                    @Html.TextBoxFor(m => m.eventDate, new { autocomplete = "off", placeholder = "Select Date", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.eventDate)
                </div>
                <div class="form-group">
                    <label>Event Head</label>
                    @Html.TextBoxFor(m => m.eventHead, new { autocomplete = "off", placeholder = "Event Head", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.eventHead)
                </div>
                <div class="form-group">
                    <label>Event Details</label>
                    @Html.TextAreaFor(m => m.eventDetails, new { autocomplete = "off", placeholder = "Event Head", rows = "5", @class = "form-control" })
                    @Html.ValidationMessageFor(z => z.eventDetails)
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="submit" id="btn-addteacher" class="btn pay-now-btn">Save</button>
            </div>
        </div>
    }
</div>

<script>
    $('#eventDate').datepicker({
        format: 'dd-mm-yyyy',
        autoclose: true,
        todayHighlight: true
    });
</script>
