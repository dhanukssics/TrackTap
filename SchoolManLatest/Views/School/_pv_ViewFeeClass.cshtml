foreach (var item in classs)
{
    <div class="col-lg-12">
        <div class="form-group">
            <label style="color:#03a9f4; margin-top:10px;">Class : @item.ClassName</label>
        </div>
    </div>

    <div class="row">
        @foreach (var item1 in item.list)
        {
        <div class="col-lg-4 feeclass-div" data-classid="@item.ClassId" data-divisionId="@item1.DivisionId">
            <div class="col-lg-4">
                <div class="form-group">
                    <label>Division : @item1.DivisionName</label>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="form-group">
                    <label>Amt</label>
                    <input type="number" class="form-control loop-class-amount" placeholder="Amt" /><label>INR</label>
                </div>
            </div>
        </div>
        }
    </div>
    <div class="row" style="border-bottom:medium;">

    </div>
    }
}
else
{
    if (Model.FeeId != 0)
    {
        <div>
            No Class To Update!
        </div>
    }
}
