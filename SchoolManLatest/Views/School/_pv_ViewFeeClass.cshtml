    var classs = new TrackTap.Data.WebsiteService().getAllClassDivisionByFeeId(Model.SchoolId, Model.FeeId).ToList();
}

@if (classs.Count > 0)
{
    //Archana Commended these lines and wrote new code for include the Division in Fee section in 21/06/2019
