    //-------------------------------------------------------------------
     $(document).on('click', '#markSave_btn', function () {
         var source = $(this);
         getFullData(source);
     });
    function getFullData(source) {
        var dataList = new Object();
        dataList.ExamId = $('#examId').val();
        dataList.SubjectId = $('#subId').val();
        dataList._ListData = [];

        $('.cls-tr-class').each(function (index, elem) {
            var data = new Object();
            data.StudentId = $(this).attr('data-StudentId');
            data.InternalMark = $(this).find('.cls-internal-mark').val();
            data.ExternalMark = $(this).find('.cls-external-mark').val();
            data.Total = parseInt(parseInt(data.InternalMark) + parseInt(data.ExternalMark));
            dataList._ListData.push(data);
        });
        console.log(dataList);
        setTimeout(function () {

            $.ajax({
                dataType: 'json',
                type: "POST",
                url: "/School/SubmitAddStudentsMarks",
                data: dataList,
                success: function (response) {
                    if (response.msg) {
                        //var data = response.UserData;
                        toastrSuccess("Successful");
                        $('#exam-student-mark-list').html(response.UserData);
                        //$.validator.unobtrusive.parse($('#tbstdMarkList'));
                        RefreshData();
                    }
                    else {
                        toastrError('No such Files!');
                    }
                },
                error: function (data) {
                }
            });
        }, 500);
    }

    function RefreshData() {
        var subjectId = $('#SubjectId').val();
        $.ajax({
            url: '/School/DatatableSubjectList/' + subjectId,
            type: "GET",
            dataType: 'html',
            success: function (data) {
                $('#exam-student-mark-list').html(data);
                //$.validator.unobtrusive.parse($('#tbstdMarkList'));
            }
        });
    }
    //--------------------------------------------------------
    //--------------tocheck internal and external mark by basheer on 28/01/2019


    function imarkchange(count)
    {
        //debugger
        var  imark = $('#internalmark').val();
        var mark = parseFloat($('#' + count).val());
        //alert(imark + "internal" + mark);
        if(mark>imark)
        {
            toastrError('Mark higher than internal mark!');
            $('#markSave_btn').css({ 'cursor': 'default', 'pointer-events': 'none', 'opacity': '.8' });
        }
        else {
            $('#markSave_btn').css({ 'cursor': 'pointer', 'pointer-events': 'initial', 'opacity': '1' });
        }

    }
    function emarkchange(externalcount) {
        var imark = $('#externalmark').val();
        var mark =  parseFloat($('#'+externalcount).val());
        //alert(mark + "test");
        if (mark > imark) {
            toastrError('Mark higher than external mark!');
            $('#markSave_btn').css({ 'cursor': 'default', 'pointer-events': 'none', 'opacity': '.8' });
        }
        else {
            $('#markSave_btn').css({ 'cursor': 'pointer', 'pointer-events': 'initial', 'opacity': '1' });
        }
    }
