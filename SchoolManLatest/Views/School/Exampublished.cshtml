</div>

<script>
    $("#btn-Publish-trial-bal").click(function () {
        var number = $(".slct-free-div-dropdown1 option:selected").val();
        $.ajax({
            type: 'POST',
            url: '@Url.Content("~/School/Exampublished_Save")',
            data: { "number": parseInt(number) },
            success: function (result) {
                if (result == 0) {
                    swal({
                        title: "Are you sure?",
                        text: "Do you want sent again!",
                        type: "warning",
                        showCancelButton: true,
                        confirmButtonClass: "btn-danger",
                        confirmButtonText: "Yes, Resent!",
                        cancelButtonText: "No, Resent!",
                        closeOnConfirm: false,
                        closeOnCancel: false
                    },
                    function (isConfirm) {
                        if (isConfirm) {
                            ////////////////////////////
                            $.ajax({
                                type: 'POST',
                                url: '@Url.Content("~/School/Exampublished_Resent")',
                                data: { "number": parseInt(number) },
                                success: function (result) {

                                }
                            });



                            //////////////////////////////////////////


                            swal("Good job!", "Sent successful", "success")
                        } else {
                            swal("Cancelled", "Sent Cancelled :)", "error");
                        }
                    });
                }
                else {
                    
                  
                    
                    
                    toastrSuccess("Sent Successful");

                }
                //$("#Test").html(result);
                
            }
        });
    });
</script>

