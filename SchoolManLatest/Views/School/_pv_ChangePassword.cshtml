@model TrackTap.Models.PasswordChangeModel
@{

}
@*@{
        ViewBag.Title = "_pv_ChangePassword";
        //Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
    }*@

@using (Ajax.BeginForm("PasswordChange", "School", null, new AjaxOptions
{
    HttpMethod = "POST",
    OnSuccess = "PasswordChangeSuccess",
    OnFailure = "PasswordChangeFailed",
}, new { id = "form-login" }))
{
    @Html.ValidationSummary(true)
    @Html.AntiForgeryToken()
    @Html.HiddenFor(z => z.SchoolId, new { Value = Model.SchoolId })
    <div class="col-md-6">
        <div class="form-group gap_bottom">
            <div class="col-md-4">
                <label>Old Password</label>
            </div>
            <div class="col-md-8">
                @Html.TextBoxFor(m => m.OldPassword, new { autocomplete = "off", placeholder = "OldPassword", type = "password", maxLength = 60, @class = "form-control" })
                @Html.ValidationMessageFor(z => z.OldPassword)
            </div>
        </div>


        <div class="form-group gap_bottom">
            <div class="col-md-4">
                <label>New Password</label>
            </div>
            <div class="col-md-8">
                @Html.TextBoxFor(m => m.Newpassword, new { autocomplete = "off", placeholder = "Newpassword", type = "password", maxLength = 60, @class = "form-control" })
                @Html.ValidationMessageFor(z => z.Newpassword)
            </div>
        </div>

        <div class="form-group gap_bottom">
            <div class="col-md-4">
                <label>Confirm Password</label>
            </div>
            <div class="col-md-8">
                @Html.TextBoxFor(m => m.ConfirmPassword, new { autocomplete = "off", placeholder = "ConfirmPassword", type = "password", maxLength = 60, @class = "form-control" })
                @Html.ValidationMessageFor(z => z.ConfirmPassword)
            </div>
        </div>


        <div class="form-group gap_bottom">
            <div class="modal-footer">
                <button type="submit" id="btn-save-daybook" class="btn pay-now-btn">Save</button>
            </div>
        </div>
    </div>
}

