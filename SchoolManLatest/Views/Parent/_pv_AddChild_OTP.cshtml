@model TrackTap.Models.StudentModel


<div class="modal-dialog">
    <!-- Modal content-->
    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" id="close-btn" data-dismiss="modal">&times;</button>
            <h4 class="modal-title">OTP</h4>
        </div>
        <div class="modal-body login-without" style="display: inline-block; margin: 0; padding: 0; background: #2a7c81; width: 100%; border-radius:0px 0px 7px 7px; ">
            <div class="login" style="padding: 0 0 !important;">
                <div class="login-form fullWid" style="background-color: #327744fa;">
                    <div class="form-group">
                        <input id="OTP-value" style="height:47px; font-family: arial;" class="newDes" placeholder="Enter OTP" />
                    </div>
                    <div class="form-group">
                        <input id="proceed-otp" type="button" value="Submit" class="submit" data-studentId="@Model.studentId" />
                    </div>
                    <p>Please check your mobile. An OTP has send to your mobile</p>
                </div>
            </div>
        </div>
    </div>
</div>
